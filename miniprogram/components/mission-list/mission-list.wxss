.mission-group {
  margin-bottom: 12rpx;
}

.mission-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ede4d7;
}

.mission-row:last-child {
  border-bottom: none;
}

.mission-toggle {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 3rpx solid #c6bcac;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
}

.mission-toggle-done {
  border-color: #6c6a49;
}

.mission-toggle-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #6c6a49;
}

.mission-copy {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2f2b24;
}

.mission-copy-done {
  color: #9a9387;
  text-decoration: line-through;
}

.mission-inline-panel {
  margin-top: 10rpx;
  margin-left: 56rpx;
  border: 1rpx solid #eadfce;
  border-radius: 36rpx;
  padding: 22rpx 18rpx 18rpx;
  background: #fffdf9;
  box-sizing: border-box;
  overflow: hidden;
}

.mission-inline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 18rpx;
}

.mission-inline-row {
  display: flex;
  gap: 12rpx;
  width: 100%;
}

.mission-inline-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mission-inline-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #6f675c;
  background: #f5eee3;
}

.mission-inline-btn {
  flex: 1 1 0;
  min-width: 0;
  min-height: 88rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #f3ece1 0%, #ece3d6 100%);
  border: 1rpx solid #e4d8c8;
  color: #2f2b24;
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0;
  box-shadow: 0 8rpx 16rpx rgba(86, 74, 56, 0.05);
  overflow: hidden;
}

.mission-inline-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 88rpx;
  width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.mission-inline-icon-image {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  opacity: 0.88;
}

.mission-inline-btn-text {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mission-note-area {
  width: 100%;
  min-height: 132rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #f7f1e8;
  border: 1rpx solid #eadfce;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4b453b;
}

.mission-verify-btn {
  width: 100%;
  margin-top: 18rpx;
  min-height: 88rpx;
  border-radius: 32rpx;
  background: #6c6a49;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.mission-review-card {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: #f7f1e8;
}

.mission-review-score {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  color: #6c6a49;
  flex-shrink: 0;
}

.mission-review-score-value {
  font-size: 40rpx;
  font-weight: 700;
}

.mission-review-score-unit {
  font-size: 20rpx;
}

.mission-review-copy {
  flex: 1;
}

.mission-review-status {
  font-size: 26rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 8rpx;
}

.mission-review-comment {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f675c;
}
