.checkin-card-shell {
  width: 100%;
}

.checkin-card-preview {
  width: 100%;
  display: block;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(103, 81, 49, 0.12);
}

.checkin-card-loading {
  padding: 48rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(247, 239, 224, 0.92), rgba(242, 232, 214, 0.96));
  border: 1rpx solid rgba(210, 188, 154, 0.45);
  color: #8c775c;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

.checkin-card-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 654rpx;
  height: 16rpx;
  opacity: 0;
  pointer-events: none;
}
