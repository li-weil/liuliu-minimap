.audio-player-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7f2ea 0%, #f1e9dc 100%);
  border: 1rpx solid #eadfce;
  box-shadow: 0 10rpx 22rpx rgba(79, 68, 50, 0.06);
}

.audio-toggle {
  flex: 0 0 33.3333%;
  max-width: 33.3333%;
  min-height: 60rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6c6a49;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  box-shadow: 0 10rpx 20rpx rgba(108, 106, 73, 0.18);
}

.audio-toggle-playing {
  background: #4d4c34;
}

.audio-main {
  flex: 0 0 66.6667%;
  max-width: 66.6667%;
  min-width: 0;
}

.audio-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.audio-progress-label {
  font-size: 24rpx;
  color: #5f594f;
  font-variant-numeric: tabular-nums;
}

.audio-error {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #b04933;
}

.audio-slider {
  margin-top: 6rpx;
}
