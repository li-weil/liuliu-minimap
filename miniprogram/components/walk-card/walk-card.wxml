<view wx:if="{{walk}}" class="walk-card" bindtap="openDetail">
  <view class="walk-card-header">
    <view class="walk-card-title">{{walk.themeTitle}}</view>
    <view class="meta-row">
      <view class="meta-pill">{{walk.recordType === 'team' ? '同行' : (walk.isPublic ? '公开' : '私密')}}</view>
      <view class="meta-pill">{{walk.albumStatusLabel || (walk.recordType === 'team' ? (walk.status === 'finished' ? '已完成' : (walk.status === 'active' ? '进行中' : '待出发')) : (walk.status === 'active' ? '进行中' : '已完成'))}}</view>
    </view>
  </view>
  <view class="meta-row walk-card-meta">
    <view class="meta-pill">{{walk.locationName || '未知地点'}}</view>
    <view wx:if="{{walk.recordType === 'team'}}" class="meta-pill">{{walk.teamStats.memberCount || 0}} 人同行</view>
    <view wx:else class="meta-pill">{{walk.routeStats.distanceLabel || '0 m'}}</view>
    <view class="meta-pill">{{walk.routeStats.durationLabel || '0秒'}}</view>
  </view>
  <view wx:if="{{walk.noteText}}" class="walk-card-note">{{walk.noteText}}</view>
  <view class="walk-card-footer">
    <view class="walk-card-date">{{walk.createdAtLabel || walk.createdAt}}</view>
    <view class="walk-card-link">{{walk.albumStatusKey === 'active' ? '查看详情并继续' : (walk.albumStatusKey === 'pending' ? '查看详情并准备' : '查看详情')}}</view>
  </view>
</view>
