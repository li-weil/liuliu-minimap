.theme-display {
  overflow: hidden;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.98), rgba(249, 244, 236, 0.96));
  border-radius: 40rpx;
  border: 1rpx solid rgba(221, 210, 194, 0.7);
  box-shadow: 0 12rpx 28rpx rgba(79, 68, 50, 0.08);
}

.display-stage {
  min-height: 340rpx;
  padding: 28rpx 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 40rpx 40rpx 0 0;
}

.display-stage::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: 36rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.display-glyph-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  width: 100%;
}

.display-glyph {
  font-size: 144rpx;
  line-height: 0.92;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 600;
}

.display-stage-title {
  margin-top: 24rpx;
  max-width: 72%;
  font-size: 38rpx;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 600;
}

.theme-content {
  padding: 30rpx 28rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 0 0 40rpx 40rpx;
}

.theme-kicker {
  font-size: 22rpx;
  color: #8d826f;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.theme-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.7;
  margin-bottom: 24rpx;
  color: #2d2a25;
}

.mission-label {
  font-size: 24rpx;
  color: #8d826f;
  margin-bottom: 14rpx;
}

.mission-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border: 1rpx solid #ede3d4;
  border-radius: 999rpx;
}

.mission-order {
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d9cfbe;
  background: #f7f1e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #5b5144;
  font-weight: 600;
  flex-shrink: 0;
}

.mission-text {
  flex: 1;
  line-height: 1.7;
  color: #3a352d;
}

.theme-start-btn {
  margin-top: 24rpx;
  min-height: 108rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #2f2b24 0%, #5a5a40 100%);
  box-shadow: 0 16rpx 28rpx rgba(60, 54, 42, 0.18);
  border-radius: 32rpx;
}

.theme-start-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
}

.theme-start-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.2;
}
