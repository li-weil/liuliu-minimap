.task-ticket {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  border-radius: 30rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.18);
  box-shadow: 0 18rpx 38rpx rgba(77, 62, 38, 0.1);
}

.task-ticket::before,
.task-ticket::after {
  content: "";
  position: absolute;
  top: 214rpx;
  z-index: 2;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f4efe6;
  border: 1rpx solid rgba(126, 111, 89, 0.12);
}

.task-ticket::before {
  left: -18rpx;
}

.task-ticket::after {
  right: -18rpx;
}

.task-ticket-error {
  border-color: rgba(165, 84, 73, 0.3);
}

.ticket-perforation {
  height: 10rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(98, 98, 71, 0.22) 0,
    rgba(98, 98, 71, 0.22) 12rpx,
    transparent 12rpx,
    transparent 24rpx
  );
}

.ticket-head {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  min-height: 204rpx;
  padding: 28rpx;
  background: #faf4ea;
  box-sizing: border-box;
  border-bottom: 1rpx dashed rgba(126, 111, 89, 0.26);
}

.task-ticket-error .ticket-head {
  background: #f7ebe7;
}

.ticket-head-copy {
  min-width: 0;
  flex: 1;
  padding-right: 22rpx;
}

.ticket-kicker {
  display: inline-block;
  max-width: 100%;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 21rpx;
  line-height: 1.25;
  word-break: break-word;
}

.task-ticket-error .ticket-kicker {
  background: rgba(165, 84, 73, 0.12);
  color: #a55449;
}

.ticket-title {
  margin-top: 18rpx;
  color: #241f19;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
  word-break: break-word;
}

.ticket-subtitle {
  margin-top: 14rpx;
  color: #746b5f;
  font-size: 23rpx;
  line-height: 1.55;
  word-break: break-word;
}

.ticket-stamp {
  width: 142rpx;
  min-height: 142rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #626247;
  color: #fffdf8;
  box-shadow: inset 0 0 0 2rpx rgba(255, 253, 248, 0.22);
}

.task-ticket-error .ticket-stamp {
  background: #a55449;
}

.ticket-stamp-main {
  max-width: 112rpx;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 750;
  text-align: center;
  word-break: break-word;
}

.ticket-stamp-sub {
  margin-top: 10rpx;
  max-width: 112rpx;
  color: rgba(255, 253, 248, 0.78);
  font-size: 20rpx;
  line-height: 1.25;
  text-align: center;
  word-break: break-word;
}

.ticket-section {
  padding: 26rpx 28rpx;
  background: #fffdf8;
  border-bottom: 1rpx solid rgba(126, 111, 89, 0.12);
}

.ticket-section-last {
  border-bottom: none;
}

.theme-description {
  color: #3a332b;
  font-size: 31rpx;
  line-height: 1.72;
  font-weight: 600;
  word-break: break-word;
}

.mission-label {
  margin-bottom: 12rpx;
  color: #9a9082;
  font-size: 22rpx;
  line-height: 1.45;
}

.ticket-mission-list {
  border-top: 1rpx solid rgba(126, 111, 89, 0.14);
}

.ticket-mission {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(126, 111, 89, 0.14);
}

.ticket-mission:last-child {
  border-bottom: none;
}

.ticket-mission-order {
  width: 50rpx;
  height: 50rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.ticket-mission-text {
  flex: 1;
  min-width: 0;
  color: #3a332b;
  font-size: 28rpx;
  line-height: 1.72;
  word-break: break-word;
}

.generation-progress-panel {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.generation-progress-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.generation-progress-title {
  flex: 1;
  min-width: 0;
  margin-right: 14rpx;
  color: #3a332b;
  font-size: 23rpx;
  line-height: 1.5;
  font-weight: 600;
  word-break: break-word;
}

.generation-progress-number {
  flex-shrink: 0;
  color: #626247;
  font-size: 23rpx;
  line-height: 1.5;
  font-weight: 700;
}

.generation-progress-track {
  position: relative;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(126, 111, 89, 0.16);
}

.generation-progress-fill {
  position: relative;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #626247 0%, #9a9577 100%);
  transition-property: width;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.generation-progress-fill::after {
  content: "";
  position: absolute;
  top: 0;
  right: -36rpx;
  width: 88rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,253,248,0), rgba(255,253,248,0.58), rgba(255,253,248,0));
  animation: generation-progress-glow 1.8s ease-in-out infinite;
}

.generation-progress-fill-error {
  background: linear-gradient(90deg, #a55449 0%, #bf8379 100%);
}

.generation-steps {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.generation-step {
  display: flex;
  align-items: center;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 11rpx 14rpx;
  border-radius: 999rpx;
  background: #faf4ea;
  color: #9a9082;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.1);
  transition-property: transform, opacity, background-color, box-shadow;
  transition-duration: 220ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.generation-step-dot {
  width: 32rpx;
  height: 32rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 700;
  background: rgba(126, 111, 89, 0.16);
  color: #746b5f;
}

.generation-step-text {
  font-size: 21rpx;
  line-height: 1.2;
}

.generation-step-done {
  color: #626247;
}

.generation-step-done .generation-step-dot {
  background: #626247;
  color: #fffdf8;
}

.generation-step-active {
  background: rgba(98, 98, 71, 0.1);
  color: #3f402f;
  box-shadow: inset 0 0 0 1rpx rgba(98, 98, 71, 0.2);
  animation: step-breathe 1.8s ease-in-out infinite;
}

.generation-step-active .generation-step-dot {
  background: #626247;
  color: #fffdf8;
}

.generation-step-error {
  background: rgba(165, 84, 73, 0.12);
  color: #a55449;
  box-shadow: inset 0 0 0 1rpx rgba(165, 84, 73, 0.22);
}

.generation-step-error .generation-step-dot {
  background: #a55449;
  color: #fffdf8;
}

.ticket-mission-placeholder {
  align-items: center;
}

.mission-skeleton {
  flex: 1;
  min-width: 0;
  padding-top: 7rpx;
}

.mission-skeleton-line {
  position: relative;
  overflow: hidden;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(126, 111, 89, 0.14);
}

.mission-skeleton-line::after {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(255,253,248,0), rgba(255,253,248,0.74), rgba(255,253,248,0));
  animation: mission-skeleton-shimmer 1.6s ease-in-out infinite;
}

.mission-skeleton-line-main {
  width: 82%;
}

.mission-skeleton-line-sub {
  width: 58%;
  margin-top: 12rpx;
}

.theme-start-btn {
  width: 100%;
  margin-top: 26rpx;
  min-height: 108rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #626247;
  box-shadow: 0 16rpx 28rpx rgba(63, 64, 47, 0.18);
  border-radius: 26rpx;
}

.theme-start-btn-disabled {
  background: #9a9082;
  box-shadow: none;
  opacity: 0.72;
}

.theme-start-main {
  color: #fffdf8;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.theme-start-sub {
  margin-top: 8rpx;
  color: rgba(255, 253, 248, 0.78);
  font-size: 22rpx;
  line-height: 1.3;
}

@keyframes generation-progress-glow {
  0% {
    transform: translateX(-24rpx);
    opacity: 0.18;
  }
  50% {
    opacity: 0.58;
  }
  100% {
    transform: translateX(14rpx);
    opacity: 0.18;
  }
}

@keyframes mission-skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}

@keyframes step-breathe {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
  100% {
    transform: scale(1);
  }
}
