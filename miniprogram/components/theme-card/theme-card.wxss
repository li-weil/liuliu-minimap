.theme-display {
  overflow: hidden;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.98), rgba(249, 244, 236, 0.96));
  border-radius: 40rpx;
  border: 1rpx solid rgba(221, 210, 194, 0.7);
  box-shadow: 0 12rpx 28rpx rgba(79, 68, 50, 0.08);
}

.display-stage {
  min-height: 340rpx;
  padding: 28rpx 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 40rpx 40rpx 0 0;
}

.display-stage::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: 36rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.display-glyph-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  width: 100%;
}

.display-glyph {
  font-size: 144rpx;
  line-height: 0.92;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 600;
}

.display-stage-title {
  margin-top: 24rpx;
  max-width: 72%;
  font-size: 38rpx;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 600;
}

.theme-display-loading {
  border-color: rgba(209, 196, 177, 0.82);
}

.generation-stage {
  overflow: hidden;
}

.generation-stage-badge {
  margin-top: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  line-height: 1.2;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.theme-content {
  padding: 30rpx 28rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 0 0 40rpx 40rpx;
}

.theme-kicker {
  font-size: 22rpx;
  color: #8d826f;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.theme-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.7;
  margin-bottom: 24rpx;
  color: #2d2a25;
}

.mission-label {
  font-size: 24rpx;
  color: #8d826f;
  margin-bottom: 14rpx;
}

.generation-progress-panel {
  padding: 18rpx 20rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(247, 241, 233, 0.86), rgba(255, 255, 255, 0.94));
  box-shadow: inset 0 0 0 1rpx rgba(229, 220, 206, 0.82);
}

.generation-progress-track {
  position: relative;
  height: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(225, 214, 195, 0.6);
}

.generation-progress-fill {
  position: relative;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #5a5a40 0%, #8f7d63 50%, #d8c19d 100%);
  transition-property: width;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.generation-progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  right: -36rpx;
  width: 88rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0));
  animation: generation-progress-glow 1.8s ease-in-out infinite;
}

.generation-progress-fill-error {
  background: linear-gradient(90deg, #8f5b5b 0%, #b67a6a 55%, #d8b29d 100%);
}

.generation-progress-copy {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #756d60;
}

.generation-steps {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.generation-step {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(242, 235, 224, 0.9);
  color: #9f9587;
  transition: all 240ms ease;
}

.generation-step-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(207, 196, 181, 0.72);
  color: #675d4f;
}

.generation-step-text {
  font-size: 22rpx;
  line-height: 1.2;
}

.generation-step-done {
  background: rgba(235, 230, 218, 0.96);
  color: #5b5448;
}

.generation-step-done .generation-step-dot {
  background: #5a5a40;
  color: #fff;
}

.generation-step-active {
  background: linear-gradient(135deg, rgba(90, 90, 64, 0.14), rgba(193, 171, 141, 0.2));
  color: #3b362e;
  box-shadow: inset 0 0 0 1rpx rgba(90, 90, 64, 0.16);
}

.generation-step-active .generation-step-dot {
  background: linear-gradient(135deg, #5a5a40, #8f7d63);
  color: #fff;
}

.generation-step-error {
  background: rgba(182, 122, 106, 0.12);
  color: #72483f;
  box-shadow: inset 0 0 0 1rpx rgba(182, 122, 106, 0.2);
}

.generation-step-error .generation-step-dot {
  background: linear-gradient(135deg, #8f5b5b, #b67a6a);
  color: #fff;
}

.mission-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border: 1rpx solid #ede3d4;
  border-radius: 999rpx;
}

.mission-order {
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d9cfbe;
  background: #f7f1e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #5b5144;
  font-weight: 600;
  flex-shrink: 0;
}

.mission-text {
  flex: 1;
  line-height: 1.7;
  color: #3a352d;
}

.mission-item-placeholder {
  align-items: center;
}

.mission-skeleton {
  flex: 1;
}

.mission-skeleton-line {
  position: relative;
  overflow: hidden;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(233, 225, 214, 0.92);
}

.mission-skeleton-line::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,0.72), rgba(255,255,255,0));
  animation: mission-skeleton-shimmer 1.6s ease-in-out infinite;
}

.mission-skeleton-line-main {
  width: 78%;
}

.mission-skeleton-line-sub {
  width: 56%;
  margin-top: 12rpx;
}

.theme-start-btn {
  margin-top: 24rpx;
  min-height: 108rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #2f2b24 0%, #5a5a40 100%);
  box-shadow: 0 16rpx 28rpx rgba(60, 54, 42, 0.18);
  border-radius: 32rpx;
}

.theme-start-btn-disabled {
  background: linear-gradient(135deg, #9d9486 0%, #b8afa2 100%);
  box-shadow: none;
}

.theme-start-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
}

.theme-start-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.2;
}

@keyframes generation-progress-glow {
  0% {
    transform: translateX(-24rpx);
    opacity: 0.18;
  }
  50% {
    opacity: 0.58;
  }
  100% {
    transform: translateX(14rpx);
    opacity: 0.18;
  }
}

@keyframes mission-skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}
