.feedback-page {
  min-height: 100vh;
}

.feedback-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.feedback-copy {
  color: #6f6a5f;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 14rpx 0 28rpx;
}

.category-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(90, 90, 64, 0.18);
  color: #6f6a5f;
  background: rgba(255, 255, 255, 0.85);
}

.category-chip-active {
  color: #5a5a40;
  border-color: rgba(90, 90, 64, 0.4);
  background: rgba(90, 90, 64, 0.08);
}

.feedback-textarea {
  width: 100%;
  min-height: 280rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fbf8f2;
  color: #2f2b24;
  line-height: 1.7;
  margin: 16rpx 0 18rpx;
}

.feedback-meta {
  color: #8a8477;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.feedback-submit {
  margin-top: 16rpx;
}
