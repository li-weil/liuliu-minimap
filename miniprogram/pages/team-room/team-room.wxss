.room-hero,
.room-section {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.room-title {
  font-size: 42rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.room-subtitle,
.room-copy,
.activity-copy,
.mission-item {
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f6a5f;
}

.room-copy {
  margin-top: 18rpx;
}

.room-meta {
  margin-bottom: 18rpx;
}

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: #f7f2ea;
}

.member-avatar,
.member-avatar-fallback {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
}

.member-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5a5a40;
  color: #fff;
  font-size: 24rpx;
}

.member-name {
  font-size: 24rpx;
  color: #2f2b24;
}

.member-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: rgba(90, 90, 64, 0.12);
  color: #5a5a40;
}

.mission-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.activity-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.activity-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.room-empty {
  padding: 20rpx 0;
}
