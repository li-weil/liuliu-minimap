.explore-page {
  background:
    radial-gradient(circle at top left, rgba(185, 106, 85, 0.16), transparent 24%),
    radial-gradient(circle at top right, rgba(82, 112, 138, 0.14), transparent 22%),
    linear-gradient(180deg, #f7f1e8 0%, #f1ebe2 100%);
}

.explore-hero,
.mode-card,
.explore-map-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.explore-hero {
  background: linear-gradient(145deg, rgba(255, 251, 245, 0.98), rgba(247, 238, 227, 0.95));
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.7;
  color: #756d60;
}

.mode-switch {
  display: inline-flex;
  background: rgba(90, 90, 64, 0.1);
  border-radius: 999rpx;
  padding: 8rpx;
}

.mode-chip {
  padding: 16rpx 34rpx;
  border-radius: 999rpx;
  color: #6f6a5f;
  font-size: 26rpx;
}

.mode-chip-active {
  background: #5a5a40;
  color: #fff;
}

.search-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  min-height: 84rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 999rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 1rpx rgba(207, 195, 179, 0.6);
}

.search-btn {
  min-width: 148rpx;
}

.hero-meta {
  margin-top: 0;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.hero-actions button {
  flex: 1;
}

.search-result-list {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(81, 65, 45, 0.08);
}

.search-result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx 16rpx;
  background: linear-gradient(180deg, rgba(248, 241, 232, 0.95), rgba(255, 255, 255, 0.92));
}

.search-result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2f2b24;
}

.search-result-count {
  font-size: 22rpx;
  color: #8a8173;
}

.search-result-scroll {
  max-height: 860rpx;
}

.search-result-item {
  padding: 22rpx 24rpx 18rpx;
  border-bottom: 1rpx solid #ece5d9;
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-name {
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.search-result-topline {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.search-result-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

.search-result-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(90, 90, 64, 0.12);
  color: #5a5a40;
  font-size: 20rpx;
  line-height: 1.2;
}

.search-result-badge-light {
  background: rgba(180, 160, 132, 0.14);
  color: #7b6b55;
}

.helper-copy {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f7a6f;
}

.explore-map-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 241, 232, 0.94));
  border-radius: 40rpx;
}

.explore-map-shell {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  margin-top: 6rpx;
}

.explore-map {
  width: 100%;
  height: 360rpx;
}

.map-center-pin {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 56rpx;
  height: 56rpx;
  margin-left: -28rpx;
  margin-top: -56rpx;
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-center-pin::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 34rpx;
  margin-left: -17rpx;
  margin-top: -17rpx;
  background: #ffffff;
  border: 6rpx solid #5a5a40;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(47, 43, 36, 0.18);
}

.map-center-pin::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -8rpx;
  margin-top: 10rpx;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 18rpx solid #5a5a40;
}

.map-center-pin-dot {
  position: relative;
  z-index: 1;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #5a5a40;
}

.map-helper-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.map-helper-copy {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f7a6f;
}

.map-confirm-btn {
  flex-shrink: 0;
  min-width: 196rpx;
}

.nearby-panel {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 0 0 1rpx rgba(228, 217, 201, 0.78);
}

.nearby-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.nearby-panel-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.nearby-panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
}

.nearby-panel-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a8173;
}

.nearby-toggle {
  min-width: 104rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  color: #5a5a40;
  background: rgba(90, 90, 64, 0.1);
  box-shadow: inset 0 0 0 1rpx rgba(90, 90, 64, 0.12);
}

.nearby-collapsed-copy {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f7a6f;
}

.nearby-list {
  max-height: 320rpx;
}

.nearby-item {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(236, 227, 212, 0.92);
  margin-bottom: 12rpx;
}

.nearby-item:last-child {
  margin-bottom: 0;
}

.nearby-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 8rpx;
}

.nearby-item-meta {
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a8173;
  margin-bottom: 6rpx;
}

.nearby-item-address,
.nearby-empty {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f7a6f;
}

.section-heading {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.action-grid button {
  flex: 1;
}

.action-tall-btn {
  min-height: 92rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.action-btn-disabled {
  opacity: 0.6;
  box-shadow: none;
  filter: saturate(0.7);
}

.section-label {
  margin-top: 8rpx;
}

.selection-row {
  margin-bottom: 18rpx;
}

.display-card-shell {
  margin-bottom: 24rpx;
}

.full-width-btn {
  width: 100%;
}

.advanced-generate-btn {
  margin-top: 12rpx;
}

.debug-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(244, 239, 231, 0.96));
}

.debug-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.debug-toggle {
  flex-shrink: 0;
  min-width: 108rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  color: #5a5a40;
  background: rgba(90, 90, 64, 0.1);
  box-shadow: inset 0 0 0 1rpx rgba(90, 90, 64, 0.12);
}

.debug-toggle-active {
  background: #5a5a40;
  color: #fff;
  box-shadow: none;
}

.debug-panel {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.debug-panel-hero {
  padding: 22rpx 22rpx 20rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(90, 90, 64, 0.12), rgba(185, 106, 85, 0.08)),
    rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(226, 216, 201, 0.84);
}

.debug-panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 10rpx;
}

.debug-panel-note {
  font-size: 22rpx;
  line-height: 1.7;
  color: #7f7a6f;
}

.debug-summary-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.debug-summary-item {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  padding: 18rpx 20rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow:
    inset 0 0 0 1rpx rgba(226, 216, 201, 0.88),
    0 8rpx 20rpx rgba(75, 62, 39, 0.03);
}

.debug-summary-label {
  font-size: 21rpx;
  color: #8a8173;
  margin-bottom: 10rpx;
  letter-spacing: 0.02em;
}

.debug-summary-value {
  font-size: 24rpx;
  line-height: 1.7;
  color: #2f2b24;
  word-break: break-all;
}

.debug-rag-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(249, 244, 235, 0.92)),
    #fff;
  box-shadow:
    inset 0 0 0 1rpx rgba(226, 216, 201, 0.9),
    0 10rpx 28rpx rgba(75, 62, 39, 0.05);
}

.debug-rag-head {
  margin-bottom: 18rpx;
}

.debug-rag-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 6rpx;
}

.debug-rag-hint {
  font-size: 21rpx;
  line-height: 1.6;
  color: #7f7a6f;
}

.debug-rag-row {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(226, 216, 201, 0.8);
}

.debug-rag-row-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.debug-rag-group {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #6f624c;
  background: rgba(185, 106, 85, 0.12);
}

.debug-rag-key {
  font-size: 23rpx;
  font-weight: 600;
  color: #2f2b24;
  word-break: break-all;
}

.debug-rag-value {
  font-size: 23rpx;
  line-height: 1.65;
  color: #4b4338;
  word-break: break-all;
  margin-bottom: 6rpx;
}

.debug-rag-help {
  font-size: 20rpx;
  line-height: 1.65;
  color: #8a8173;
}

.debug-json-card {
  padding: 20rpx;
  border-radius: 28rpx;
  background: #1f1d1a;
  box-shadow: 0 16rpx 34rpx rgba(31, 29, 26, 0.18);
}

.debug-json-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.debug-json-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 4rpx;
}

.debug-json-hint {
  font-size: 20rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.62);
}

.debug-json-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.14);
}

.debug-json-scroll {
  max-height: 760rpx;
}

.debug-json-scroll-compact {
  max-height: 520rpx;
}

.debug-json-block {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.debug-json-line {
  font-size: 20rpx;
  line-height: 1.7;
  color: #f5efe6;
  word-break: break-all;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
}

.debug-empty {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f7a6f;
}
