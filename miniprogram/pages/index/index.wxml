<view class="page-shell explore-page">
  <view class="hero-card explore-hero">
    <view class="hero-topline">
      <view>
        <view class="hero-title">探索页</view>
        <view class="hero-subtitle">为今天的城市留下一条独特线索，让漫步从此刻的灵感开始</view>
      </view>
      <view class="mode-switch">
        <view class="mode-chip {{walkMode === 'pure' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="pure">纯粹</view>
        <view class="mode-chip {{walkMode === 'advanced' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="advanced">进阶</view>
      </view>
    </view>

    <view class="field-label section-label">出发方式</view>
    <view class="pill-row selection-row">
      <view class="{{journeyMode === 'solo' ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="journeyMode" data-value="solo">单人</view>
      <view class="{{journeyMode === 'team' ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="journeyMode" data-value="team">同行</view>
    </view>
    <view class="helper-copy">{{journeyMode === 'team' ? '同行模式会创建一个房间，邀请伙伴一起出发。' : '单人模式会直接进入记录页，围绕今天的主题开始漫步。'}}</view>

    <view class="search-panel">
      <input class="search-input" placeholder="搜索地点或街区" value="{{searchKeyword}}" bindinput="handleSearchInput" confirm-type="search" bindconfirm="searchLocation" />
      <button class="ghost-btn search-btn" bindtap="searchLocation" loading="{{loadingSearch}}">搜索</button>
    </view>

    <view class="meta-row hero-meta">
      <view class="meta-pill">{{locationName}}</view>
      <view class="meta-pill">{{walkMode === 'advanced' ? '3 个任务' : '1 个任务'}}</view>
      <view class="meta-pill">{{journeyMode === 'team' ? '同行模式' : '单人模式'}}</view>
    </view>

    <view class="hero-actions">
      <button class="ghost-btn" bindtap="useCurrentLocation">当前定位</button>
      <button class="ghost-btn" bindtap="handleChooseLocation">地图选点</button>
    </view>

    <view wx:if="{{searchResults.length}}" class="search-result-list">
      <view class="search-result-head">
        <view class="search-result-title">地点候选</view>
        <view class="search-result-count">可下滑查看更多 · {{searchResultCount}} 条</view>
      </view>
      <scroll-view scroll-y class="search-result-scroll">
        <view wx:for="{{searchResults}}" wx:key="id" class="search-result-item" bindtap="chooseSearchResult" data-index="{{index}}">
          <view class="search-result-topline">
            <view class="search-result-name">{{item.name}}</view>
          </view>
          <view wx:if="{{item.district || item.typeLabels.length}}" class="search-result-badges">
            <view wx:if="{{item.district}}" class="search-result-badge">{{item.district}}</view>
            <view wx:for="{{item.typeLabels}}" wx:key="index" class="search-result-badge search-result-badge-light">{{item}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="section-card explore-map-card">
    <view class="section-heading">
      <view>
        <view class="section-title">探索地图</view>
        <view class="section-subtitle">把视线落在一片街区上，让这次漫步从你此刻想靠近的地方展开</view>
      </view>
      <view class="meta-pill">{{locationName}}</view>
    </view>
    <view class="explore-map-shell">
      <map
        id="explore-map"
        longitude="{{longitude || 116.39747}}"
        latitude="{{latitude || 39.908823}}"
        scale="{{mapScale}}"
        show-location
        markers="{{mapMarkers}}"
        circles="{{mapCircles}}"
        bindregionchange="handleMapRegionChange"
        class="explore-map"
      />
      <view class="map-center-pin">
        <view class="map-center-pin-dot"></view>
      </view>
    </view>
    <view class="map-helper-row">
      <view class="map-helper-copy">{{isMapDragging ? '慢慢移动，寻找最想走进去的那一片街景' : '把定位针停在此刻最想出发的地方'}}</view>
      <button class="primary-btn map-confirm-btn" bindtap="confirmMapCenterLocation">设为探索点</button>
    </view>

    <view wx:if="{{supportsNearbyPois}}" class="nearby-panel">
      <view class="nearby-panel-head">
        <view>
          <view class="nearby-panel-title">周边地点推荐</view>
          <view class="nearby-panel-subtitle">沿着这个点位往外看一圈，挑一个更想走近的地方</view>
        </view>
        <view class="nearby-panel-actions">
          <view wx:if="{{loadingNearbyPlaces}}" class="meta-pill">加载中</view>
          <view wx:else class="nearby-toggle" bindtap="toggleNearbyPanel">{{nearbyExpanded ? '收起' : '展开'}}</view>
        </view>
      </view>
      <view wx:if="{{nearbyPlaces.length && !nearbyExpanded}}" class="nearby-collapsed-copy">先看看这一带有哪些值得拐进去的地方，点“展开”就能切换新的探索点</view>
      <scroll-view wx:elif="{{nearbyPlaces.length}}" scroll-y class="nearby-list">
        <view wx:for="{{nearbyPlaces}}" wx:key="id" class="nearby-item" bindtap="chooseNearbyPlace" data-index="{{index}}">
          <view class="nearby-item-name">{{item.name}}</view>
          <view wx:if="{{item.district || item.type}}" class="nearby-item-meta">
            <text wx:if="{{item.district}}">{{item.district}}</text>
            <text wx:if="{{item.type}}">{{item.district ? ' · ' : ''}}{{item.type}}</text>
          </view>
          <view wx:if="{{item.address}}" class="nearby-item-address">{{item.address}}</view>
        </view>
      </scroll-view>
      <view wx:elif="{{loadingNearbyPlaces}}" class="nearby-empty">正在把这片街区里值得停下来的地点整理出来</view>
      <view wx:else class="nearby-empty">先定位、搜索或设定探索点，这里就会出现周边地点推荐</view>
    </view>
  </view>

  <view wx:if="{{walkMode === 'pure'}}" class="mode-board">
    <view class="section-card mode-card">
      <view class="section-title">漫步主题</view>

      <view class="field-label section-label">主题选择（1 个或 2 个）</view>
      <view class="pill-row selection-row">
        <view wx:for="{{combineOptionViews}}" wx:key="label" class="{{item.active ? 'pill-active' : 'pill'}}" bindtap="toggleCombineSelection" data-value="{{item.label}}">{{item.label}}</view>
      </view>
      <view class="helper-copy">让主题先落下来，再从街道、光影和情绪里抽出今天的漫步线索</view>
      <view class="action-grid">
        <button class="ghost-btn action-tall-btn" bindtap="handleRandomTheme" loading="{{isGenerating}}">随机生成</button>
        <button class="primary-btn action-tall-btn" bindtap="handleSelectedThemeGenerate" loading="{{isCombining}}">选择生成</button>
      </view>
    </view>

    <view class="display-card-shell">
      <theme-card
        theme="{{currentTheme}}"
        modeLabel="纯粹模式"
        displaySummary="{{displaySummary}}"
        startMain="{{journeyMode === 'team' ? '发起同行漫步' : '开始这次漫步'}}"
        startSub="{{journeyMode === 'team' ? '把这份主题分享给队友，一起出发' : '带着这份线索，走进今天的城市片刻'}}"
        bind:start="handleStartWalk"
      />
    </view>
  </view>

  <view wx:else class="mode-board">
    <view class="section-card mode-card">
      <view class="field-label">天气</view>
      <view class="pill-row selection-row">
        <view wx:for="{{weatherOptions}}" wx:key="item" class="{{weather === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="weather" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">季节</view>
      <view class="pill-row selection-row">
        <view wx:for="{{seasonOptions}}" wx:key="item" class="{{season === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="season" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">状态</view>
      <view class="pill-row selection-row">
        <view wx:for="{{moodOptions}}" wx:key="item" class="{{mood === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="mood" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">偏好</view>
      <view class="pill-row selection-row">
        <view wx:for="{{preferenceOptions}}" wx:key="item" class="{{preference === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="preference" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">漫步主题（1 个或 2 个）</view>
      <view class="pill-row selection-row">
        <view wx:for="{{combineOptionViews}}" wx:key="label" class="{{item.active ? 'pill-active' : 'pill'}}" bindtap="toggleCombineSelection" data-value="{{item.label}}">{{item.label}}</view>
      </view>
      <view class="helper-copy">AI 会综合天气、季节、状态、偏好和你选定的主题方向来生成任务内容</view>

      <button class="primary-btn full-width-btn advanced-generate-btn" bindtap="handleGenerateTheme" loading="{{isGenerating}}">AI 生成</button>
    </view>

    <view class="display-card-shell">
      <theme-card
        theme="{{currentTheme}}"
        modeLabel="进阶模式"
        displaySummary="{{displaySummary}}"
        startMain="{{journeyMode === 'team' ? '发起同行漫步' : '开始这次漫步'}}"
        startSub="{{journeyMode === 'team' ? '把这份主题分享给队友，一起出发' : '带着这份线索，走进今天的城市片刻'}}"
        bind:start="handleStartWalk"
      />
    </view>
  </view>

  <privacy-consent
    visible="{{privacyPopup.visible}}"
    title="{{privacyPopup.title}}"
    content="{{privacyPopup.content}}"
    buttonText="{{privacyPopup.buttonText}}"
    contractName="{{privacyPopup.contractName}}"
    bind:agree="handlePrivacyAgree"
    bind:close="handlePrivacyReject"
    bind:opencontract="handleOpenPrivacyContract"
  />
</view>
