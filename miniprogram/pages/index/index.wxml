<view class="page-shell explore-page">
  <view class="hero-card explore-hero">
    <view class="hero-topline">
      <view>
        <view class="hero-title">探索页</view>
        <view class="hero-subtitle">为今天的城市留下一条独特线索，让漫步从此刻的灵感开始</view>
      </view>
      <view class="mode-switch">
        <view class="mode-chip {{walkMode === 'pure' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="pure">纯粹</view>
        <view class="mode-chip {{walkMode === 'advanced' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="advanced">进阶</view>
      </view>
    </view>

    <view class="field-label section-label">出发方式</view>
    <view class="pill-row selection-row">
      <view class="{{journeyMode === 'solo' ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="journeyMode" data-value="solo">单人</view>
      <view class="{{journeyMode === 'team' ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="journeyMode" data-value="team">同行</view>
    </view>
    <view class="helper-copy">{{journeyMode === 'team' ? '同行模式会创建一个房间，邀请伙伴一起出发。' : '单人模式会直接进入记录页，围绕今天的主题开始漫步。'}}</view>

    <view class="search-panel">
      <input class="search-input" placeholder="搜索地点或街区" value="{{searchKeyword}}" bindinput="handleSearchInput" confirm-type="search" bindconfirm="searchLocation" />
      <button class="ghost-btn search-btn" bindtap="searchLocation" loading="{{loadingSearch}}">搜索</button>
    </view>

    <view class="meta-row hero-meta">
      <view class="meta-pill">{{locationName}}</view>
      <view class="meta-pill">{{walkMode === 'advanced' ? '3 个任务' : '1 个任务'}}</view>
      <view class="meta-pill">{{journeyMode === 'team' ? '同行模式' : '单人模式'}}</view>
    </view>

    <view class="hero-actions">
      <button class="ghost-btn" bindtap="useCurrentLocation">当前定位</button>
      <button class="ghost-btn" bindtap="handleChooseLocation">地图选点</button>
    </view>

    <view wx:if="{{searchResults.length}}" class="search-result-list">
      <view class="search-result-head">
        <view class="search-result-title">地点候选</view>
        <view class="search-result-count">可下滑查看更多 · {{searchResultCount}} 条</view>
      </view>
      <scroll-view scroll-y class="search-result-scroll">
        <view wx:for="{{searchResults}}" wx:key="id" class="search-result-item" bindtap="chooseSearchResult" data-index="{{index}}">
          <view class="search-result-topline">
            <view class="search-result-name">{{item.name}}</view>
          </view>
          <view wx:if="{{item.district || item.typeLabels.length}}" class="search-result-badges">
            <view wx:if="{{item.district}}" class="search-result-badge">{{item.district}}</view>
            <view wx:for="{{item.typeLabels}}" wx:key="index" class="search-result-badge search-result-badge-light">{{item}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="section-card explore-map-card">
    <view class="section-heading">
      <view>
        <view class="section-title">探索地图</view>
        <view class="section-subtitle">把视线落在一片街区上，让这次漫步从你此刻想靠近的地方展开</view>
      </view>
      <view class="meta-pill">{{locationName}}</view>
    </view>
    <view class="explore-map-shell">
      <map
        id="explore-map"
        longitude="{{longitude || 116.39747}}"
        latitude="{{latitude || 39.908823}}"
        scale="{{mapScale}}"
        show-location
        markers="{{mapMarkers}}"
        circles="{{mapCircles}}"
        bindregionchange="handleMapRegionChange"
        class="explore-map"
      />
      <view class="map-center-pin">
        <view class="map-center-pin-dot"></view>
      </view>
    </view>
    <view class="map-helper-row">
      <view class="map-helper-copy">{{isMapDragging ? '慢慢移动，寻找最想走进去的那一片街景' : '把定位针停在此刻最想出发的地方'}}</view>
      <button class="primary-btn map-confirm-btn" bindtap="confirmMapCenterLocation">设为探索点</button>
    </view>
    <view class="helper-copy">{{hasConfirmedExplorePoint ? '探索点已设定，现在可以生成主题并开始这次漫步。' : '当前默认点仅用于展示，请先定位、搜索地点，或拖图后点“设为探索点”'}}</view>

    <view wx:if="{{supportsNearbyPois}}" class="nearby-panel">
      <view class="nearby-panel-head">
        <view>
          <view class="nearby-panel-title">周边地点推荐</view>
          <view class="nearby-panel-subtitle">沿着这个点位往外看一圈，挑一个更想走近的地方</view>
        </view>
        <view class="nearby-panel-actions">
          <view wx:if="{{loadingNearbyPlaces}}" class="meta-pill">加载中</view>
          <view wx:else class="nearby-toggle" bindtap="toggleNearbyPanel">{{nearbyExpanded ? '收起' : '展开'}}</view>
        </view>
      </view>
      <view wx:if="{{nearbyPlaces.length && !nearbyExpanded}}" class="nearby-collapsed-copy">先看看这一带有哪些值得拐进去的地方，点“展开”就能切换新的探索点</view>
      <scroll-view wx:elif="{{nearbyPlaces.length}}" scroll-y class="nearby-list">
        <view wx:for="{{nearbyPlaces}}" wx:key="id" class="nearby-item" bindtap="chooseNearbyPlace" data-index="{{index}}">
          <view class="nearby-item-name">{{item.name}}</view>
          <view wx:if="{{item.district || item.type}}" class="nearby-item-meta">
            <text wx:if="{{item.district}}">{{item.district}}</text>
            <text wx:if="{{item.type}}">{{item.district ? ' · ' : ''}}{{item.type}}</text>
          </view>
          <view wx:if="{{item.address}}" class="nearby-item-address">{{item.address}}</view>
        </view>
      </scroll-view>
      <view wx:elif="{{loadingNearbyPlaces}}" class="nearby-empty">正在把这片街区里值得停下来的地点整理出来</view>
    </view>
  </view>

  <view wx:if="{{walkMode === 'pure'}}" class="mode-board">
    <view class="section-card mode-card">
      <view class="section-title">漫步主题</view>

      <view class="field-label section-label">主题选择</view>
      <view class="pill-row selection-row">
        <view wx:for="{{combineOptionViews}}" wx:key="label" class="{{item.active ? 'pill-active' : 'pill'}}" bindtap="toggleCombineSelection" data-value="{{item.label}}">{{item.label}}</view>
      </view>
      <view class="helper-copy">先选定一个主题方向，再从街道、光影和情绪里抽出今天的漫步线索</view>
      <view class="action-grid">
        <button class="ghost-btn action-tall-btn {{!hasConfirmedExplorePoint ? 'action-btn-disabled' : ''}}" bindtap="handleRandomTheme" loading="{{isGenerating}}">随机生成</button>
        <button class="primary-btn action-tall-btn {{!hasConfirmedExplorePoint ? 'action-btn-disabled' : ''}}" bindtap="handleSelectedThemeGenerate" loading="{{isCombining}}">选择生成</button>
      </view>
    </view>

    <view class="display-card-shell">
      <theme-card
        theme="{{currentTheme}}"
        modeLabel="纯粹模式"
        displaySummary="{{displaySummary}}"
        startDisabled="{{!hasConfirmedExplorePoint}}"
        startMain="{{journeyMode === 'team' ? '发起同行漫步' : '开始这次漫步'}}"
        startSub="{{hasConfirmedExplorePoint ? (journeyMode === 'team' ? '把这份主题分享给队友，一起出发' : '带着这份线索，走进今天的城市片刻') : '先设定探索点，再开始这次漫步'}}"
        bind:start="handleStartWalk"
      />
    </view>
  </view>

  <view wx:else class="mode-board">
    <view class="section-card mode-card">
      <view class="field-label">天气</view>
      <view class="pill-row selection-row">
        <view wx:for="{{weatherOptions}}" wx:key="item" class="{{weather === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="weather" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">季节</view>
      <view class="pill-row selection-row">
        <view wx:for="{{seasonOptions}}" wx:key="item" class="{{season === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="season" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">状态</view>
      <view class="pill-row selection-row">
        <view wx:for="{{moodOptions}}" wx:key="item" class="{{mood === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="mood" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">偏好</view>
      <view class="pill-row selection-row">
        <view wx:for="{{preferenceOptions}}" wx:key="item" class="{{preference === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="preference" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">漫步主题（1 个或 2 个）</view>
      <view class="pill-row selection-row">
        <view wx:for="{{combineOptionViews}}" wx:key="label" class="{{item.active ? 'pill-active' : 'pill'}}" bindtap="toggleCombineSelection" data-value="{{item.label}}">{{item.label}}</view>
      </view>
      <view class="helper-copy">先设定探索点，再让 AI 综合天气、季节、状态、偏好和主题方向生成任务内容</view>

      <button class="primary-btn full-width-btn advanced-generate-btn {{!hasConfirmedExplorePoint ? 'action-btn-disabled' : ''}}" bindtap="handleGenerateTheme" loading="{{isGenerating}}">AI 生成</button>
    </view>

    <view class="display-card-shell">
      <theme-card
        theme="{{currentTheme}}"
        modeLabel="进阶模式"
        displaySummary="{{displaySummary}}"
        startDisabled="{{!hasConfirmedExplorePoint}}"
        startMain="{{journeyMode === 'team' ? '发起同行漫步' : '开始这次漫步'}}"
        startSub="{{hasConfirmedExplorePoint ? (journeyMode === 'team' ? '把这份主题分享给队友，一起出发' : '带着这份线索，走进今天的城市片刻') : '先设定探索点，再开始这次漫步'}}"
        bind:start="handleStartWalk"
      />
    </view>
  </view>

  <view class="section-card debug-card">
    <view class="debug-card-head">
      <view>
        <view class="section-title">生成调试</view>
        <view class="section-subtitle">查看最近一次真正传给模型的基础上下文，方便核对时间、附近、场景和返回结果是否对齐</view>
      </view>
      <view class="debug-toggle {{showGenerationDebug ? 'debug-toggle-active' : ''}}" bindtap="toggleGenerationDebug">
        {{showGenerationDebug ? '隐藏' : '显示'}}
      </view>
    </view>

    <view wx:if="{{showGenerationDebug}}">
      <view wx:if="{{debugContextAvailable}}">
        <view class="debug-panel">
          <view class="debug-panel-hero">
            <view class="debug-panel-title">这次真正传给模型的基础信息</view>
            <view class="debug-panel-note">先看摘要，再看完整 JSON，方便快速判断时间、附近、主题输入和最终结果是否对齐</view>
          </view>

          <view class="debug-summary-grid">
            <view wx:for="{{debugContextRows}}" wx:key="label" class="debug-summary-item">
              <view class="debug-summary-label">{{item.label}}</view>
              <view class="debug-summary-value">{{item.value}}</view>
            </view>
          </view>

          <view wx:if="{{debugRagRows.length}}" class="debug-rag-card">
            <view class="debug-rag-head">
              <view class="debug-rag-title">RAG 字段说明</view>
              <view class="debug-rag-hint">这里解释本次检索计划和调试字段，方便判断主题、场景、锚点有没有跑偏</view>
            </view>
            <view wx:for="{{debugRagRows}}" wx:key="key" class="debug-rag-row">
              <view class="debug-rag-row-head">
                <text class="debug-rag-group">{{item.group}}</text>
                <text class="debug-rag-key">{{item.label}}</text>
              </view>
              <view class="debug-rag-value">{{item.value}}</view>
              <view class="debug-rag-help">{{item.help}}</view>
            </view>
          </view>

          <view wx:if="{{debugRagPlanLines.length}}" class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">rag.plan</view>
                <view class="debug-json-hint">模型生成前的检索计划，包含目标主题、主场景、角度、锚点和反例约束</view>
              </view>
              <view class="debug-json-pill">RAG 计划</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
              <view class="debug-json-block">
                <view wx:for="{{debugRagPlanLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>

          <view wx:if="{{debugRagDebugLines.length}}" class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">rag.debug</view>
                <view class="debug-json-hint">检索过程的调试信息，包含场景候选分数、主题覆盖、锚点覆盖和召回模板 ID</view>
              </view>
              <view class="debug-json-pill">RAG 调试</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
              <view class="debug-json-block">
                <view wx:for="{{debugRagDebugLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>

          <view wx:if="{{debugRagModelInputLines.length}}" class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">rag.modelInput</view>
                <view class="debug-json-hint">真正传进模型 prompt 的 RAG 原始内容，用来核对模型到底参考了哪些场景、样例和生成计划</view>
              </view>
              <view class="debug-json-pill">入模 RAG</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll">
              <view class="debug-json-block">
                <view wx:for="{{debugRagModelInputLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>

          <view wx:if="{{debugModelRequestLines.length}}" class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">模型完整输入</view>
                <view class="debug-json-hint">这里展示本次真正提交给模型接口的完整请求对象，包括模型名、system prompt、user prompt 和约束性提示</view>
              </view>
              <view class="debug-json-pill">Model</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll">
              <view class="debug-json-block">
                <view wx:for="{{debugModelRequestLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>

          <view wx:if="{{debugModelResponseLines.length}}" class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">模型原始返回</view>
                <view class="debug-json-hint">这里展示模型接口返回的原始文本、去代码块后的文本，以及当前程序解析出的 JSON，方便判断问题出在模型还是后处理</view>
              </view>
              <view class="debug-json-pill">Raw</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll">
              <view class="debug-json-block">
                <view wx:for="{{debugModelResponseLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>

          <view wx:if="{{debugValidationLoopCards.length}}" class="debug-loop-section">
            <view class="debug-rag-card">
              <view class="debug-rag-head">
                <view class="debug-rag-title">AI Review / Rewrite 轮次记录</view>
                <view class="debug-rag-hint">这里按轮次展示每次 review 的结果页、建议改写内容，以及真正改写后的主题结果，不再只看最后一轮</view>
              </view>
            </view>

            <view wx:for="{{debugValidationLoopCards}}" wx:key="key" class="debug-loop-card">
              <view class="debug-json-head">
                <view>
                  <view class="debug-json-title">{{item.title}}</view>
                  <view class="debug-json-hint">逐轮查看输入主题、review 结论、建议改写和实际改写产物</view>
                </view>
                <view class="debug-json-pill">Loop</view>
              </view>

              <view class="debug-summary-grid debug-loop-grid">
                <view wx:for="{{item.summaryRows}}" wx:key="label" class="debug-summary-item">
                  <view class="debug-summary-label">{{item.label}}</view>
                  <view class="debug-summary-value">{{item.value}}</view>
                </view>
              </view>

              <view wx:if="{{item.inputThemeLines.length}}" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} 输入主题</view>
                    <view class="debug-json-hint">这一轮 review 之前，真正送进校验链路的主题内容</view>
                  </view>
                  <view class="debug-json-pill">Input</view>
                </view>
                <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
                  <view class="debug-json-block">
                    <view wx:for="{{item.inputThemeLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>

              <view wx:if="{{item.precheckLines.length}}" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} precheck</view>
                    <view class="debug-json-hint">这一轮进入 AI review 前的结构预检结果</view>
                  </view>
                  <view class="debug-json-pill">Precheck</view>
                </view>
                <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
                  <view class="debug-json-block">
                    <view wx:for="{{item.precheckLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>

              <view wx:if="{{item.reviewLines.length}}" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} review 结果</view>
                    <view class="debug-json-hint">这一轮 review 最终返回的结果页；如果中间做过字段补全，这里展示补全后的最终 review JSON</view>
                  </view>
                  <view class="debug-json-pill">Review</view>
                </view>
                <scroll-view scroll-y class="debug-json-scroll">
                  <view class="debug-json-block">
                    <view wx:for="{{item.reviewLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>

              <view wx:if="{{item.rewrittenSuggestionLines.length}}" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} 建议改写内容</view>
                    <view class="debug-json-hint">review 阶段要求模型改写时，模型给出的建议版本</view>
                  </view>
                  <view class="debug-json-pill">Suggested</view>
                </view>
                <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
                  <view class="debug-json-block">
                    <view wx:for="{{item.rewrittenSuggestionLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>

              <view wx:if="{{item.rewrittenThemeLines.length}}" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} 改写后结果</view>
                    <view class="debug-json-hint">这一轮真正合并并 finalize 之后的主题内容</view>
                  </view>
                  <view class="debug-json-pill">Rewritten</view>
                </view>
                <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
                  <view class="debug-json-block">
                    <view wx:for="{{item.rewrittenThemeLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>

              <view wx:for="{{item.attemptCards}}" wx:key="key" class="debug-json-card debug-loop-json-card">
                <view class="debug-json-head">
                  <view>
                    <view class="debug-json-title">{{item.title}} 原始返回</view>
                    <view class="debug-json-hint">如果这一轮做过 repair，这里能看到每次 review / repair 的原始 JSON 返回</view>
                  </view>
                  <view class="debug-json-pill">Raw</view>
                </view>
                <view class="debug-loop-attempt-meta">缺失字段：{{item.missingFields}}</view>
                <scroll-view scroll-y class="debug-json-scroll debug-json-scroll-compact">
                  <view class="debug-json-block">
                    <view wx:for="{{item.lines}}" wx:key="index" class="debug-json-line">{{item}}</view>
                  </view>
                </scroll-view>
              </view>
            </view>
          </view>

          <view class="debug-json-card">
            <view class="debug-json-head">
              <view>
                <view class="debug-json-title">contextPacket</view>
                <view class="debug-json-hint">完整原文 JSON，适合对照字段与排查偏差</view>
              </view>
              <view class="debug-json-pill">原文</view>
            </view>
            <scroll-view scroll-y class="debug-json-scroll">
              <view class="debug-json-block">
                <view wx:for="{{debugContextLines}}" wx:key="index" class="debug-json-line">{{item}}</view>
              </view>
            </scroll-view>
          </view>
        </view>
      </view>
      <view wx:else class="debug-empty">还没有生成过主题。先点一次“AI 生成 / 随机生成 / 选择生成”，这里就会显示本次传给模型的上下文。</view>
    </view>
  </view>

  <privacy-consent
    visible="{{privacyPopup.visible}}"
    title="{{privacyPopup.title}}"
    content="{{privacyPopup.content}}"
    buttonText="{{privacyPopup.buttonText}}"
    contractName="{{privacyPopup.contractName}}"
    bind:agree="handlePrivacyAgree"
    bind:close="handlePrivacyReject"
    bind:opencontract="handleOpenPrivacyContract"
  />
</view>
