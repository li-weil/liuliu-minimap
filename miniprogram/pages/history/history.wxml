<view class="page-shell history-page">
  <view class="hero-card history-hero">
    <view class="hero-topline">
      <view>
        <view class="section-title">足迹</view>
        <view class="section-subtitle">{{user ? '你的漫步纪念与成就会按当前登录账户自动整理。' : (loginState === 'paused' ? '你刚刚主动退出过账号，恢复登录后就能继续查看这位用户的漫步历史。' : '第一次使用时完善一次资料，之后就会自动带出属于你的漫步历史。')}}</view>
      </view>
      <view wx:if="{{featuredAchievement}}" class="featured-chip">
        <view class="featured-chip-label">当前佩戴</view>
        <view class="featured-chip-title">{{featuredAchievement.title}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{!user}}" class="section-card history-placeholder">
    <view class="section-title">{{loginState === 'paused' ? '已暂停自动登录' : '还没有个人资料'}}</view>
    <view class="section-subtitle">{{loginState === 'paused' ? '去个人页点一次登录，就会重新恢复当前微信账户。' : '去个人页完成一次头像和昵称设置，之后就能自动查看这位用户自己的纪念卡册和成就。'}}</view>
    <button class="primary-btn" bindtap="goToProfile">{{loginState === 'paused' ? '去恢复登录' : '去完善资料'}}</button>
  </view>

  <view wx:else class="section-card history-tabs">
    <view class="mode-switch">
      <view class="mode-chip {{activeTab === 'album' ? 'mode-chip-active' : ''}}" bindtap="switchTab" data-tab="album">纪念卡册</view>
      <view class="mode-chip {{activeTab === 'achievement' ? 'mode-chip-active' : ''}}" bindtap="switchTab" data-tab="achievement">成就</view>
    </view>
  </view>

  <view wx:if="{{user && activeTab === 'album'}}">
    <view wx:if="{{!loading && walks.length}}">
      <walk-card wx:for="{{walks}}" wx:key="_id" walk="{{item}}" bind:open="openDetail" />
    </view>
    <view wx:elif="{{loading}}" class="empty-copy">正在整理你的纪念卡册...</view>
    <view wx:else class="section-card history-placeholder">
      <view class="section-title">纪念卡册</view>
      <view class="section-subtitle">这里会放 AI 根据一次漫步内容生成的纪念卡，当前先留空。</view>
    </view>
  </view>

  <view wx:elif="{{user}}" class="achievement-board">
    <view class="achievement-summary-row">
      <view>
        <view class="achievement-summary-title">最近获得的成就</view>
        <view class="achievement-summary-subtitle">点击勋章查看详情、进度和分享入口</view>
      </view>
      <view class="achievement-summary-meta">
        <view class="achievement-summary-count">{{achievementSummary.unlockedCount}}</view>
        <view class="achievement-summary-label">总成就 {{achievementSummary.totalCount || 8}} 枚</view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="empty-copy">正在整理你的成就进度...</view>

    <view wx:else class="achievement-grid-compact">
      <view
        wx:for="{{achievements}}"
        wx:key="id"
        class="achievement-badge-item"
        bindtap="openAchievementDetail"
        data-id="{{item.id}}"
      >
        <view class="achievement-badge-shell {{item.unlocked ? 'achievement-badge-shell-on' : 'achievement-badge-shell-off'}}">
          <image
            wx:if="{{item.assetUrl}}"
            class="achievement-badge-image"
            src="{{item.assetUrl}}"
            mode="aspectFit"
            binderror="handleAchievementImageError"
            data-id="{{item.id}}"
          />
          <view wx:else class="achievement-badge-image achievement-badge-placeholder">
            <view class="achievement-badge-placeholder-glyph">{{item.progressLabel}}</view>
          </view>
        </view>
        <view class="achievement-badge-title">{{item.title}}</view>
        <view class="achievement-badge-progress">{{item.progressText}}</view>
      </view>
    </view>
  </view>
</view>
