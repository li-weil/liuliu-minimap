.history-page {
  background: #f5f2ed;
}

.history-hero,
.history-tabs,
.history-placeholder {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.featured-chip {
  min-width: 248rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 244, 223, 0.96), rgba(244, 227, 196, 0.96));
}

.featured-chip-label {
  font-size: 20rpx;
  color: #8d7b5d;
}

.featured-chip-body {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.featured-chip-image {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
}

.featured-chip-image-placeholder {
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top right, rgba(255, 241, 220, 0.96), transparent 42%),
    linear-gradient(135deg, #f0e0c7, #d9c2a0);
  color: #5b4b37;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.44);
}

.featured-chip-glyph {
  font-size: 24rpx;
  font-weight: 600;
}

.featured-chip-copy {
  min-width: 0;
}

.featured-chip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4f4232;
  line-height: 1.35;
}

.featured-chip-subtitle {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8d7b5d;
}

.mode-switch {
  display: inline-flex;
  background: rgba(90, 90, 64, 0.08);
  border-radius: 999rpx;
  padding: 8rpx;
}

.mode-chip {
  padding: 16rpx 34rpx;
  border-radius: 999rpx;
  color: #6f6a5f;
  font-size: 26rpx;
}

.mode-chip-active {
  background: #5a5a40;
  color: #fff;
}

.achievement-board {
  padding: 8rpx 4rpx 0;
}

.album-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 8rpx;
}

.album-filter-panel {
  padding: 26rpx 28rpx;
  margin-bottom: 18rpx;
}

.album-filter-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.album-filter-reset {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(90, 90, 64, 0.08);
  color: #5a5a40;
  font-size: 22rpx;
}

.album-filter-group {
  margin-top: 20rpx;
}

.album-filter-group-label {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #8b816f;
}

.album-filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 2rpx 0 0;
}

.album-filter-row-secondary {
  padding-top: 0;
}

.album-filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 238, 0.9);
  border: 1rpx solid rgba(214, 194, 167, 0.68);
  color: #6f6658;
  font-size: 24rpx;
}

.album-filter-chip-active {
  background: rgba(255, 248, 238, 0.9);
  border-color: #5a5a40;
  color: #5a5a40;
  box-shadow: 0 10rpx 24rpx rgba(90, 90, 64, 0.08);
}

.album-filter-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(90, 90, 64, 0.1);
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
  color: inherit;
}

.album-filter-chip-active .album-filter-count {
  background: rgba(90, 90, 64, 0.1);
}

.album-filter-meta {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.album-filter-summary-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 244, 223, 0.96), rgba(244, 227, 196, 0.96));
  color: #5a4e3d;
  font-size: 22rpx;
  font-weight: 600;
}

.album-filter-result-count {
  font-size: 22rpx;
  color: #8b816f;
}

.achievement-summary-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 12rpx 10rpx 20rpx;
}

.achievement-summary-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #322a1f;
}

.achievement-summary-subtitle {
  margin-top: 8rpx;
  color: #7e7667;
  font-size: 22rpx;
}

.achievement-summary-meta {
  text-align: right;
}

.achievement-summary-count {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 700;
  color: #4c3f2f;
}

.achievement-summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c816e;
}

.achievement-grid-compact {
  display: flex;
  flex-wrap: wrap;
  row-gap: 34rpx;
  column-gap: 2%;
}

.achievement-badge-item {
  width: 32%;
  text-align: center;
}

.achievement-badge-shell {
  position: relative;
  width: 100%;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.achievement-badge-shell-off {
  filter: grayscale(1);
  opacity: 0.56;
}

.achievement-badge-image {
  width: 92%;
  height: 92%;
  display: block;
}

.achievement-badge-placeholder {
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 241, 220, 0.96), transparent 42%),
    linear-gradient(135deg, #f0e0c7, #d9c2a0);
  color: #5b4b37;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.44);
}

.achievement-badge-placeholder-glyph {
  font-size: 42rpx;
  font-weight: 600;
}

.achievement-badge-title {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.35;
  color: #352d23;
  min-height: 70rpx;
}

.achievement-badge-progress {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8b816f;
}
