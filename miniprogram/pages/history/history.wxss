.history-page {
  background: linear-gradient(180deg, #f4efe6 0%, #efe7da 100%);
  padding-bottom: 48rpx;
}

.history-hero,
.history-placeholder,
.filter-summary-bar,
.achievement-summary-row,
.recent-achievements,
.history-loading {
  animation: history-panel-enter 340ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.history-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(77, 62, 38, 0.08);
}

.history-hero-main {
  flex: 1;
  min-width: 0;
  padding-right: 22rpx;
}

.history-kicker {
  display: inline-block;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 21rpx;
  line-height: 1.25;
}

.history-title {
  margin-top: 18rpx;
  color: #241f19;
  font-size: 46rpx;
  line-height: 1.16;
  font-weight: 700;
}

.history-subtitle {
  margin-top: 14rpx;
  color: #746b5f;
  font-size: 25rpx;
  line-height: 1.65;
  word-break: break-word;
}

.featured-achievement {
  width: 142rpx;
  min-height: 176rpx;
  flex-shrink: 0;
  padding: 16rpx 14rpx;
  border-radius: 24rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.featured-label {
  width: 100%;
  color: #9a9082;
  font-size: 20rpx;
  line-height: 1.25;
  text-align: center;
}

.featured-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  width: 100%;
}

.featured-image {
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto;
  flex-shrink: 0;
  display: block;
}

.featured-placeholder,
.achievement-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #efe7da;
  color: #626247;
  box-shadow: inset 0 0 0 1rpx rgba(98, 98, 71, 0.14);
}

.featured-glyph {
  font-size: 30rpx;
  font-weight: 700;
}

.history-placeholder {
  padding: 30rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 14rpx 32rpx rgba(77, 62, 38, 0.07);
}

.placeholder-title {
  color: #241f19;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
}

.placeholder-copy {
  margin-top: 12rpx;
  color: #746b5f;
  font-size: 24rpx;
  line-height: 1.65;
}

.placeholder-btn {
  width: 100%;
  margin-top: 24rpx;
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.history-tabs {
  display: flex;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.history-tab {
  flex: 1;
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #746b5f;
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 650;
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.history-tab:active,
.history-tab-press {
  transform: scale(0.985);
  opacity: 0.86;
}

.history-tab-active {
  background: #fffdf8;
  color: #3f402f;
  box-shadow: 0 8rpx 18rpx rgba(77, 62, 38, 0.08);
}

.filter-summary-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
}

.filter-summary-main {
  min-width: 0;
  flex: 1;
  padding-right: 16rpx;
}

.filter-summary-title {
  color: #241f19;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 700;
}

.filter-summary-copy {
  margin-top: 6rpx;
  color: #746b5f;
  font-size: 22rpx;
  line-height: 1.35;
}

.filter-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.filter-text-action,
.filter-toggle {
  min-height: 52rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.filter-text-action {
  margin-right: 10rpx;
  color: #746b5f;
}

.filter-toggle {
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
}

.album-filter-shell {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-12rpx);
  transition-property: max-height, opacity, transform;
  transition-duration: 280ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: max-height, opacity, transform;
}

.album-filter-shell-open {
  max-height: 520rpx;
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.album-filter-panel {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.album-filter-group {
  margin-bottom: 22rpx;
}

.album-filter-group:last-child {
  margin-bottom: 0;
}

.album-filter-group-label {
  margin-bottom: 12rpx;
  color: #746b5f;
  font-size: 22rpx;
  line-height: 1.35;
}

.album-filter-row {
  display: flex;
  flex-wrap: wrap;
}

.album-filter-chip {
  display: flex;
  align-items: center;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 13rpx 18rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  color: #746b5f;
  font-size: 23rpx;
  line-height: 1.25;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.album-filter-chip:active,
.album-filter-chip-press {
  transform: scale(0.98);
  opacity: 0.86;
}

.album-filter-chip-active {
  background: rgba(98, 98, 71, 0.1);
  color: #3f402f;
  box-shadow: inset 0 0 0 2rpx rgba(98, 98, 71, 0.3);
}

.album-filter-count {
  min-width: 32rpx;
  height: 32rpx;
  margin-left: 9rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(126, 111, 89, 0.12);
  color: inherit;
  font-size: 19rpx;
  line-height: 32rpx;
  text-align: center;
}

.album-list {
  padding-top: 6rpx;
  opacity: 1;
  transform: translateY(0);
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.album-list-switching {
  opacity: 0.38;
  transform: translateY(10rpx);
}

.album-pagination {
  margin-top: 12rpx;
  padding: 18rpx 0 4rpx;
}

.album-page-summary {
  margin-bottom: 12rpx;
  color: #9a9082;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: center;
}

.album-page-scroll {
  width: 100%;
  white-space: nowrap;
}

.album-page-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 100%;
  padding: 2rpx 0 8rpx;
}

.album-page-number,
.album-page-ellipsis {
  height: 58rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 23rpx;
  line-height: 1.2;
}

.album-page-number {
  width: 58rpx;
  background: #fffdf8;
  color: #3f402f;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.16);
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.album-page-number-active {
  background: #626247;
  color: #fffdf8;
  box-shadow: 0 8rpx 18rpx rgba(77, 62, 38, 0.12);
}

.album-page-number:active,
.album-page-number-press {
  transform: scale(0.97);
  opacity: 0.86;
}

.album-page-ellipsis {
  width: 44rpx;
  color: #746b5f;
}

.album-jump-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 10rpx;
  padding: 0 25%;
  box-sizing: border-box;
}

.album-jump-input {
  flex: 1;
  width: 0;
  min-width: 0;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fffdf8;
  color: #241f19;
  font-size: 23rpx;
  line-height: 64rpx;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.16);
}

.album-jump-btn {
  flex: 1;
  width: 0;
  min-width: 0;
  height: 64rpx;
  min-height: 64rpx;
  margin-left: 0;
  padding: 0;
  flex-shrink: 0;
  border-radius: 16rpx;
  font-size: 23rpx;
  line-height: 64rpx;
  box-sizing: border-box;
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
}

.history-button-press {
  transform: scale(0.975);
  opacity: 0.86;
}

.album-end-copy {
  padding: 20rpx 12rpx 8rpx;
  color: #9a9082;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.achievement-board {
  padding-top: 2rpx;
}

.achievement-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 26rpx 28rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
}

.achievement-summary-title {
  color: #241f19;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
}

.achievement-summary-subtitle {
  margin-top: 8rpx;
  color: #746b5f;
  font-size: 23rpx;
  line-height: 1.45;
}

.achievement-summary-meter {
  min-width: 136rpx;
  text-align: right;
}

.achievement-summary-count {
  color: #626247;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 750;
}

.achievement-summary-label {
  margin-top: 8rpx;
  color: #9a9082;
  font-size: 21rpx;
  line-height: 1.25;
}

.recent-achievements {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
}

.recent-head {
  margin-bottom: 18rpx;
}

.recent-title {
  color: #241f19;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 700;
}

.recent-copy {
  margin-top: 8rpx;
  color: #746b5f;
  font-size: 22rpx;
  line-height: 1.45;
}

.recent-scroll {
  white-space: nowrap;
}

.recent-strip {
  display: flex;
}

.recent-achievement-card {
  width: 220rpx;
  margin-right: 16rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
  box-sizing: border-box;
}

.recent-achievement-image {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
}

.recent-achievement-title {
  margin-top: 12rpx;
  color: #3a332b;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 650;
  text-align: center;
  word-break: break-word;
}

.achievement-grid-compact {
  display: flex;
  flex-wrap: wrap;
  margin-left: -1%;
  margin-right: -1%;
}

.achievement-badge-item {
  width: 31.33%;
  margin-left: 1%;
  margin-right: 1%;
  margin-bottom: 30rpx;
  text-align: center;
  transition-property: transform, opacity;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.achievement-badge-item:active {
  transform: scale(0.98);
  opacity: 0.86;
}

.achievement-badge-shell {
  width: 100%;
  height: 196rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #fffdf8;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.12);
}

.achievement-badge-shell-off {
  opacity: 0.46;
}

.achievement-badge-image {
  width: 90%;
  height: 90%;
  display: block;
}

.achievement-placeholder-glyph {
  font-size: 38rpx;
  font-weight: 700;
}

.achievement-badge-title {
  margin-top: 10rpx;
  color: #3a332b;
  font-size: 24rpx;
  line-height: 1.35;
  min-height: 64rpx;
  word-break: break-word;
}

.achievement-badge-progress {
  margin-top: 4rpx;
  color: #8a8173;
  font-size: 21rpx;
  line-height: 1.35;
}

.history-loading {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
}

.history-skeleton {
  position: relative;
  overflow: hidden;
  height: 26rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(126, 111, 89, 0.14);
}

.history-skeleton:first-child {
  margin-top: 0;
}

.history-skeleton-lg {
  height: 132rpx;
  border-radius: 26rpx;
}

.history-skeleton-short {
  width: 58%;
}

.history-skeleton::after {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(255,253,248,0), rgba(255,253,248,0.72), rgba(255,253,248,0));
  animation: history-skeleton-shimmer 1.6s ease-in-out infinite;
}

@keyframes history-panel-enter {
  0% {
    opacity: 0;
    transform: translateY(16rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes history-skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}
