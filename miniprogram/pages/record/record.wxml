<view class="page-shell" wx:if="{{theme && draft}}">
  <view class="theme-card record-hero">
    <view wx:if="{{isTracking}}" class="record-map-stage">
      <map
        longitude="{{draft.longitude || 116.39747}}"
        latitude="{{draft.latitude || 39.908823}}"
        scale="15"
        show-location
        polyline="{{[{ points: draft.routePoints, color: '#5a5a40', width: 4 }]}}"
        style="width: 100%; height: 360rpx;"
      />
    </view>
    <view wx:else class="record-stage" style="background: linear-gradient(135deg, {{theme.vibeColor || '#5a5a40'}} 0%, #f1eadf 100%);">
      <view class="record-stage-glyph">{{theme.displayGlyph || '遛'}}</view>
      <view class="record-stage-copy">
        <view class="record-stage-title">{{theme.title}}</view>
        <view class="record-stage-desc">{{theme.description}}</view>
      </view>
    </view>
    <view class="record-body">
      <view class="meta-row">
        <view class="meta-pill">{{draft.locationName}}</view>
        <view class="meta-pill">{{draft.walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}</view>
        <view class="meta-pill">{{draft.completedMissions.length}} / {{theme.missions.length}} 已完成</view>
      </view>
    </view>
  </view>

  <button class="map-switch-btn" bindtap="toggleTracking">{{isTracking ? '停止追踪' : '开启轨迹追踪'}}</button>

  <view class="section-card section-block track-stats-block">
    <view class="section-title">轨迹信息</view>
    <view class="track-stats-grid">
      <view class="track-stat-card">
        <view class="track-stat-value">{{routeStats.durationLabel}}</view>
        <view class="track-stat-label">总时长</view>
      </view>
      <view class="track-stat-card">
        <view class="track-stat-value">{{routeStats.distanceLabel}}</view>
        <view class="track-stat-label">里程估算</view>
      </view>
    </view>
    <view class="track-time-row">
      <view class="track-time-item">开始：{{routeStats.startedLabel}}</view>
      <view class="track-time-item">结束：{{routeStats.stoppedLabel}}</view>
    </view>
  </view>

  <view class="section-card section-block">
    <view class="section-title">任务打卡</view>
    <mission-list missions="{{theme.missions}}" activeMission="{{activeMission}}" expandedMission="{{expandedMission}}" completedMissions="{{draft.completedMissions}}" missionReviews="{{draft.missionReviews}}" missionAssetMap="{{draft.missionAssetMap}}" bind:select="selectMission" bind:verify="handleMissionVerify" bind:toggle="toggleMissionDone" bind:missionnote="handleMissionNoteInput" />
  </view>

  <view class="section-card section-block">
    <view class="section-title">记录与追踪</view>
    <view class="section-subtitle">把沿途留下的光影、声音和感受收拢起来，成为这次漫步的回声</view>

    <view class="record-tools-grid">
      <button class="tool-btn" bindtap="choosePhoto">
        <view class="tool-btn-inner">
          <image class="tool-icon-image" src="/assets/icons/camera.svg" mode="aspectFit" />
          <text class="tool-btn-text">随手拍</text>
        </view>
      </button>
      <button class="tool-btn" bindtap="chooseVideo">
        <view class="tool-btn-inner">
          <image class="tool-icon-image" src="/assets/icons/video.svg" mode="aspectFit" />
          <text class="tool-btn-text">录像</text>
        </view>
      </button>
      <button class="tool-btn" bindtap="toggleAudioRecording">
        <view class="tool-btn-inner">
          <image class="tool-icon-image" src="/assets/icons/mic.svg" mode="aspectFit" />
          <text class="tool-btn-text">{{isRecordingAudio ? '停止录音' : '录音'}}</text>
        </view>
      </button>
    </view>

    <textarea class="summary-area" placeholder="写下这一段路给你的感受、画面或突然冒出的念头..." value="{{draft.noteText}}" bindinput="handleNoteInput" maxlength="500" />

    <view wx:if="{{draft.photoList.length}}" class="media-preview-block">
      <scroll-view scroll-x>
        <view class="media-scroll">
          <view wx:for="{{draft.photoList}}" wx:key="index" class="media-thumb">
            <image src="{{item}}" mode="aspectFill" class="media-image" />
            <view class="danger-btn media-remove" bindtap="removePhoto" data-index="{{index}}">删</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{draft.videoList.length}}" class="asset-list">
      <view wx:for="{{draft.videoList}}" wx:key="index" class="asset-row">
        <view>
          <view class="asset-title">视频 {{index + 1}}</view>
          <view class="asset-meta">{{item.duration}} 秒</view>
        </view>
        <button class="ghost-btn" size="mini" bindtap="removeVideo" data-index="{{index}}">删除</button>
      </view>
    </view>

    <view wx:if="{{draft.audioList.length || isRecordingAudio}}" class="asset-list">
      <view wx:if="{{isRecordingAudio}}" class="asset-row">
        <view>
          <view class="asset-title">正在收集此刻的声音</view>
          <view class="asset-meta">等这一段声响落定，再把它留在这次漫步里</view>
        </view>
      </view>
      <view wx:for="{{draft.audioList}}" wx:key="index" class="asset-row">
        <view>
          <view class="asset-title">录音 {{index + 1}}</view>
          <view class="asset-meta">{{item.duration}} ms</view>
        </view>
        <button class="ghost-btn" size="mini" bindtap="removeAudio" data-index="{{index}}">删除</button>
      </view>
    </view>
  </view>

  <view class="section-card section-block">
    <view class="section-title">打卡贴纸</view>
    <view class="section-subtitle">让这次漫步的主题和任务，凝成一张可以留住情绪的小纸片</view>
    <button class="primary-btn sticker-generate-btn" bindtap="handleGenerateSticker" loading="{{isGeneratingSticker}}">
      {{draft.sticker && draft.sticker.imageUrl ? '重新生成打卡贴纸' : '生成打卡贴纸'}}
    </button>

    <view wx:if="{{draft.sticker}}" class="sticker-preview-card" bindtap="openStickerModal">
      <image wx:if="{{draft.sticker.imageUrl}}" class="sticker-preview-image" src="{{draft.sticker.imageUrl}}" mode="aspectFill" />
      <view wx:else class="sticker-preview-placeholder"></view>
      <view class="sticker-preview-overlay">
        <view class="sticker-preview-poem">
          <view wx:for="{{draft.sticker.poemColumns}}" wx:key="index" class="sticker-preview-poem-column">
            <view wx:for="{{item}}" wx:key="subIndex" class="sticker-preview-poem-char">{{item}}</view>
          </view>
        </view>
        <view class="sticker-preview-theme">{{draft.sticker.title || theme.title}}</view>
      </view>
    </view>
  </view>

  <button class="primary-btn save-btn" bindtap="handleSave" loading="{{isSaving}}">完成本次漫步并保存</button>

  <view wx:if="{{showStickerModal}}" class="sticker-modal-mask" catchtap="closeStickerModal">
    <view class="sticker-modal-sheet" catchtap="noop">
      <view class="sticker-modal-card">
        <image wx:if="{{draft.sticker.imageUrl}}" class="sticker-modal-image" src="{{draft.sticker.imageUrl}}" mode="aspectFill" />
        <view wx:else class="sticker-modal-placeholder"></view>
        <view class="sticker-modal-overlay">
          <view class="sticker-modal-poem">
            <view wx:for="{{draft.sticker.poemColumns}}" wx:key="index" class="sticker-modal-poem-column">
              <view wx:for="{{item}}" wx:key="subIndex" class="sticker-modal-poem-char">{{item}}</view>
            </view>
          </view>
          <view class="sticker-modal-theme">{{draft.sticker.title || theme.title}}</view>
        </view>
      </view>
      <view class="sticker-modal-actions">
        <button class="ghost-btn sticker-modal-action" bindtap="handleShareStickerFromRecord">分享链接</button>
        <button class="primary-btn sticker-modal-action" bindtap="handleSaveStickerToAlbum">保存到本地</button>
      </view>
    </view>
  </view>
</view>

<view wx:else class="page-shell empty-copy">还没有属于今天的漫步主题，先去探索页挑一段想走的城市情绪吧</view>
