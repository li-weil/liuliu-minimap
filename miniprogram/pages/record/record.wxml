<view class="page-shell" wx:if="{{theme && draft}}">
  <view class="theme-card record-hero">
    <view wx:if="{{isTracking}}" class="record-map-stage">
      <map
        longitude="{{draft.longitude || 116.39747}}"
        latitude="{{draft.latitude || 39.908823}}"
        scale="15"
        show-location
        polyline="{{[{ points: draft.routePoints, color: '#5a5a40', width: 4 }]}}"
        style="width: 100%; height: 360rpx;"
      />
    </view>
    <view wx:else class="record-stage" style="background: linear-gradient(135deg, {{theme.vibeColor || '#5a5a40'}} 0%, #f1eadf 100%);">
      <view class="record-stage-glyph">{{theme.displayGlyph || '遛'}}</view>
      <view class="record-stage-copy">
        <view class="record-stage-title">{{theme.title}}</view>
        <view class="record-stage-desc">{{theme.description}}</view>
      </view>
    </view>
    <view class="record-body">
      <view class="meta-row">
        <view class="meta-pill">{{draft.locationName}}</view>
        <view class="meta-pill">{{draft.walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}</view>
        <view class="meta-pill">{{draft.completedMissions.length}} / {{theme.missions.length}} 已完成</view>
      </view>
    </view>
  </view>

  <button class="map-switch-btn" bindtap="toggleTracking">{{isTracking ? '停止追踪' : '开启轨迹追踪'}}</button>

  <view class="section-card section-block track-stats-block">
    <view class="section-title">轨迹信息</view>
    <view class="track-stats-grid">
      <view class="track-stat-card">
        <view class="track-stat-value">{{routeStats.durationLabel}}</view>
        <view class="track-stat-label">总时长</view>
      </view>
      <view class="track-stat-card">
        <view class="track-stat-value">{{routeStats.distanceLabel}}</view>
        <view class="track-stat-label">里程估算</view>
      </view>
    </view>
    <view class="track-time-row">
      <view class="track-time-item">开始：{{routeStats.startedLabel}}</view>
      <view class="track-time-item">结束：{{routeStats.stoppedLabel}}</view>
    </view>
  </view>

  <view class="section-card section-block">
    <view class="section-title">任务打卡</view>
    <mission-list
      missions="{{theme.missions}}"
      supplementalMissionKey="{{summaryMissionKey}}"
      supplementalMissionLabel="总结与补充"
      activeMission="{{activeMission}}"
      expandedMission="{{expandedMission}}"
      completedMissions="{{draft.completedMissions}}"
      missionReviews="{{draft.missionReviews}}"
      missionAssetMap="{{draft.missionAssetMap}}"
      generatedMissionCardMap="{{generatedMissionCardMap}}"
      isRecordingAudio="{{isRecordingAudio}}"
      recordingMission="{{recordingMission || ''}}"
      locationName="{{draft.locationName}}"
      themeTitle="{{theme.title}}"
      dateLabel="{{routeStats.startedLabel}}"
      accentColor="{{theme.vibeColor || '#c96f4a'}}"
      bind:select="selectMission"
      bind:verify="handleMissionVerify"
      bind:toggle="toggleMissionDone"
      bind:missionnote="handleMissionNoteInput"
      bind:generatecard="handleGenerateMissionCard"
      bind:removephoto="removeMissionPhoto"
      bind:removevideo="removeMissionVideo"
      bind:removeaudio="removeMissionAudio"
    />
  </view>

  <button class="primary-btn save-btn" bindtap="handleSave" loading="{{isSaving}}">完成本次漫步并保存</button>

  <checkin-card
    mission="{{missionCardRenderPayload.mission}}"
    assets="{{missionCardRenderPayload.assets}}"
    locationName="{{draft.locationName}}"
    themeTitle="{{theme.title}}"
    dateLabel="{{routeStats.startedLabel}}"
    accentColor="{{theme.vibeColor || '#c96f4a'}}"
    renderVersion="{{missionCardRenderPayload.renderVersion}}"
    autoRender="{{true}}"
    bind:generated="handleMissionCardGenerated"
  />

  <view wx:if="{{showMissionCardModal}}" class="mission-card-modal-mask" catchtap="closeMissionCardModal">
    <view class="mission-card-modal-sheet" catchtap="noop">
      <view class="mission-card-modal-panel">
        <view class="mission-card-modal-title">{{missionCardModal.mission || '打卡卡片'}}</view>
        <scroll-view scroll-y class="mission-card-modal-scroll">
          <view wx:if="{{missionCardModal.isGenerating}}" class="mission-card-modal-loading">正在生成打卡卡片...</view>
          <image wx:elif="{{missionCardModal.imageSrc}}" class="mission-card-modal-image" src="{{missionCardModal.imageSrc}}" mode="widthFix" />
        </scroll-view>
      </view>
      <view class="mission-card-modal-actions">
        <button class="ghost-btn mission-card-modal-action" bindtap="closeMissionCardModal">关闭</button>
        <button class="primary-btn mission-card-modal-action" bindtap="handleSaveMissionCardToAlbum" disabled="{{!missionCardModal.imageSrc || missionCardModal.isGenerating}}">保存到本地</button>
      </view>
    </view>
  </view>
</view>

<view wx:else class="page-shell empty-copy">还没有属于今天的漫步主题，先去探索页挑一段想走的城市情绪吧</view>
