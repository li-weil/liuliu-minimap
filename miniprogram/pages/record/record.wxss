.record-page {
  background: linear-gradient(180deg, #f4efe6 0%, #efe7da 100%);
  padding-bottom: 0;
}

.record-hero,
.location-status-bar,
.track-time-strip,
.mission-workbench {
  animation: record-panel-enter 340ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.record-hero {
  overflow: hidden;
  margin-bottom: 22rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(77, 62, 38, 0.09);
}

.record-theme-stage {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  min-height: 246rpx;
  padding: 30rpx 28rpx;
  background: #faf4ea;
  box-sizing: border-box;
  border-bottom: 1rpx dashed rgba(126, 111, 89, 0.24);
}

.record-theme-copy {
  min-width: 0;
  flex: 1;
  padding-right: 22rpx;
}

.record-kicker {
  display: inline-block;
  max-width: 100%;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 21rpx;
  line-height: 1.25;
  word-break: break-word;
}

.record-stage-title {
  margin-top: 18rpx;
  color: #241f19;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  word-break: break-word;
}

.record-stage-desc {
  margin-top: 14rpx;
  color: #746b5f;
  font-size: 25rpx;
  line-height: 1.65;
  word-break: break-word;
}

.record-stage-stamp {
  width: 138rpx;
  min-height: 138rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #626247;
  color: #fffdf8;
  box-shadow: inset 0 0 0 2rpx rgba(255, 253, 248, 0.22);
}

.record-stage-glyph {
  max-width: 108rpx;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 750;
  text-align: center;
  word-break: break-word;
}

.record-stage-stamp-text {
  margin-top: 10rpx;
  color: rgba(255, 253, 248, 0.78);
  font-size: 20rpx;
  line-height: 1.25;
}

.record-map-stage {
  overflow: hidden;
  height: 380rpx;
  background: #efe7da;
}

.record-map {
  width: 100%;
  height: 380rpx;
}

.record-hero-footer {
  padding: 24rpx 28rpx 28rpx;
}

.record-meta-grid {
  display: flex;
  margin-bottom: 22rpx;
}

.record-meta-item {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.record-meta-label {
  color: #9a9082;
  font-size: 21rpx;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.record-meta-value {
  color: #3a332b;
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 600;
  word-break: break-word;
}

.hero-progress-head {
  display: flex;
  justify-content: space-between;
  color: #746b5f;
  font-size: 22rpx;
  line-height: 1.35;
  margin-bottom: 12rpx;
}

.hero-progress-track {
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(126, 111, 89, 0.16);
}

.hero-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: #626247;
  transition-property: width;
  transition-duration: 260ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.location-status-bar {
  display: grid;
  grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr);
  column-gap: 12rpx;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 12rpx 28rpx rgba(77, 62, 38, 0.06);
}

.location-status-copy-cell {
  min-width: 0;
  display: flex;
  align-items: center;
}

.location-status-dot {
  width: 20rpx;
  height: 20rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #b88445;
  box-shadow: 0 0 0 8rpx rgba(184, 132, 69, 0.12);
}

.location-status-dot-active {
  background: #66704a;
  box-shadow: 0 0 0 8rpx rgba(102, 112, 74, 0.14);
  animation: location-pulse 1.8s ease-in-out infinite;
}

.location-status-main {
  min-width: 0;
}

.location-status-title {
  color: #241f19;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 700;
}

.location-status-copy {
  margin-top: 6rpx;
  color: #746b5f;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-word;
}

.location-status-duration {
  min-width: 0;
  text-align: center;
}

.location-status-number {
  color: #3f402f;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
}

.location-status-label {
  margin-top: 4rpx;
  color: #9a9082;
  font-size: 19rpx;
  line-height: 1.25;
}

.location-toggle-cell {
  min-width: 0;
  width: 100%;
}

.location-toggle-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 72rpx;
  padding: 18rpx 6rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
  box-sizing: border-box;
}

.track-time-strip {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(250, 244, 234, 0.86);
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.12);
}

.track-time-item {
  flex: 1;
  min-width: 0;
}

.track-time-label {
  color: #9a9082;
  font-size: 20rpx;
  line-height: 1.25;
  margin-bottom: 6rpx;
}

.track-time-value {
  color: #3a332b;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 600;
  word-break: break-word;
}

.track-time-divider {
  width: 1rpx;
  height: 46rpx;
  margin: 0 20rpx;
  background: rgba(126, 111, 89, 0.18);
}

.mission-workbench {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(77, 62, 38, 0.08);
}

.mission-workbench-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.mission-count-badge {
  min-width: 82rpx;
  margin-left: 18rpx;
  padding: 11rpx 16rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
}

.record-save-spacer {
  height: 168rpx;
}

.save-action-bar {
  position: sticky;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  margin-left: -32rpx;
  margin-right: -32rpx;
  padding: 18rpx 32rpx 28rpx;
  background: rgba(244, 239, 230, 0.96);
  border-top: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 -12rpx 28rpx rgba(77, 62, 38, 0.08);
}

.save-btn {
  width: 100%;
  min-height: 96rpx;
  line-height: 1.2;
}

.save-progress-card {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.save-progress-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.save-progress-title {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
  color: #241f19;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 650;
  word-break: break-word;
}

.save-progress-percent {
  flex-shrink: 0;
  color: #626247;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
}

.save-progress-meta {
  margin-top: 8rpx;
  color: #746b5f;
  font-size: 21rpx;
  line-height: 1.45;
}

.save-progress-track {
  margin-top: 14rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(126, 111, 89, 0.16);
  overflow: hidden;
}

.save-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: #626247;
  transition-property: width;
  transition-duration: 220ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes record-panel-enter {
  0% {
    opacity: 0;
    transform: translateY(16rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes location-pulse {
  0% {
    transform: scale(1);
    opacity: 0.86;
  }
  50% {
    transform: scale(1.16);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 0.86;
  }
}
