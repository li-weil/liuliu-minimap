.record-hero,
.section-block {
  margin-bottom: 24rpx;
}

.record-hero {
  overflow: hidden;
  border-radius: 40rpx;
  border: 1rpx solid rgba(221, 210, 194, 0.7);
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.98), rgba(249, 244, 236, 0.96));
  box-shadow: 0 12rpx 28rpx rgba(79, 68, 50, 0.08);
}

.record-stage {
  padding: 32rpx;
  min-height: 220rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  border-radius: 40rpx 40rpx 0 0;
}

.record-stage-glyph {
  font-size: 120rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.record-stage-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.record-stage-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.record-stage-desc {
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
}

.record-map-stage {
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}

.record-body {
  padding: 24rpx 28rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 0 0 40rpx 40rpx;
}

.section-block {
  padding: 28rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a8173;
}

.map-switch-btn {
  width: calc(100% - 64rpx);
  margin: 0 32rpx 24rpx;
  border-radius: 999rpx;
  background: #ebe4d9;
  color: #2f2b24;
  font-size: 28rpx;
  padding: 22rpx 28rpx;
}

.record-tools-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 22rpx 0 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.tool-btn {
  width: 100%;
  min-height: 96rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  padding: 0;
  background: linear-gradient(180deg, #f3ece1 0%, #ece3d6 100%);
  color: #2f2b24;
  border: 1rpx solid #e4d8c8;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 8rpx 16rpx rgba(86, 74, 56, 0.05);
}

.tool-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  min-height: 96rpx;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.tool-icon-image {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
  opacity: 0.88;
}

.tool-btn-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
  white-space: nowrap;
}

.summary-area {
  width: 100%;
  min-height: 220rpx;
  background: linear-gradient(180deg, #f6f1e8 0%, #f1eadf 100%);
  border-radius: 36rpx;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
  margin: 4rpx 0 20rpx;
  border: 1rpx solid #ede4d7;
  font-size: 28rpx;
  line-height: 1.7;
  color: #4b453b;
}

.media-preview-block {
  margin-bottom: 18rpx;
}

.media-scroll {
  display: flex;
  gap: 16rpx;
}

.media-thumb {
  position: relative;
}

.media-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 28rpx;
}

.media-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 10rpx 14rpx;
  font-size: 22rpx;
}

.asset-list {
  margin-bottom: 8rpx;
}

.asset-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece3d6;
}

.asset-row:last-child {
  border-bottom: none;
}

.asset-title {
  font-size: 28rpx;
}

.asset-meta {
  font-size: 22rpx;
  color: #8b8377;
  margin-top: 8rpx;
}

.save-btn {
  width: 360rpx;
  margin: 8rpx auto 0;
}
