.detail-hero,
.detail-section {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.detail-copy,
.detail-summary,
.mission-state,
.contribution-note,
.activity-item {
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f6a5f;
}

.detail-summary {
  margin-top: 16rpx;
}

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: #f7f2ea;
}

.member-avatar,
.member-avatar-fallback {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
}

.member-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5a5a40;
  color: #fff;
}

.mission-group {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.mission-group:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.mission-title,
.contribution-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
}

.contribution-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f7f2ea;
}

.activity-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.activity-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-empty {
  padding: 20rpx 0;
}
