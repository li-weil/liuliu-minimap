<view class="page-shell">
  <view class="hero-card profile-hero">
    <view class="section-title">我的账户</view>
    <view class="section-subtitle">{{user ? '你的漫步资料已经留在这里，随时可以继续出发' : '同步微信资料后，就能保存属于你的漫步轨迹与记录'}}</view>
  </view>

  <view wx:if="{{user}}" class="section-card profile-card">
    <view class="profile-user-row">
      <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="profile-avatar" />
      <view wx:else class="profile-avatar profile-avatar-fallback">留</view>
      <view class="profile-copy">
        <view class="profile-name">{{user.nickName}}</view>
        <view class="profile-meta-id">{{user.openid || user._id}}</view>
      </view>
    </view>
    <view class="meta-row profile-meta-row">
      <view class="meta-pill">角色 {{user.role || 'user'}}</view>
      <view class="meta-pill">已同步</view>
    </view>
    <button class="ghost-btn profile-logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <view wx:if="{{!user}}" class="section-card profile-card">
    <view class="profile-setup-row">
      <button class="profile-avatar-picker" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image wx:if="{{draftAvatarUrl}}" src="{{draftAvatarUrl}}" class="profile-avatar" />
        <view wx:else class="profile-avatar profile-avatar-fallback">选</view>
      </button>
      <view class="profile-form-block">
        <input class="profile-nickname-input" type="nickname" placeholder="写下想展示的昵称" value="{{draftNickName}}" bindinput="handleNickNameInput" />
      </view>
    </view>
    <button class="primary-btn profile-login-btn" bindtap="handleLogin" loading="{{syncing}}">登录并同步资料</button>
  </view>

</view>
