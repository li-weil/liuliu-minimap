<view class="page-shell">
  <view class="hero-card profile-hero">
    <view class="section-title">我的账户</view>
    <view class="section-subtitle">{{user ? '你的漫步资料已经留在这里，随时可以继续出发' : '同步微信资料后，就能保存属于你的漫步轨迹与记录'}}</view>
  </view>

  <view wx:if="{{user}}" class="section-card profile-card">
    <view class="profile-user-row">
      <image src="{{user.avatarUrl}}" class="profile-avatar" />
      <view class="profile-copy">
        <view class="profile-name">{{user.nickName}}</view>
        <view class="profile-meta-id">{{user.openid || user._id}}</view>
      </view>
    </view>
    <view class="meta-row profile-meta-row">
      <view class="meta-pill">角色 {{user.role || 'user'}}</view>
      <view class="meta-pill">已同步</view>
    </view>
    <button class="ghost-btn profile-logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <button wx:if="{{!user}}" class="primary-btn profile-login-btn" bindtap="handleLogin" loading="{{syncing}}">微信登录并同步资料</button>

  <view class="section-card profile-section">
    <view class="section-title">当前 MVP 能力</view>
    <view class="mission-card profile-capability-card">AI 主题生成</view>
    <view class="mission-card profile-capability-card">图片 视频 录音与轨迹记录</view>
    <view class="mission-card profile-capability-card">足迹保存与历史回看</view>
  </view>

  <button class="ghost-btn profile-draft-btn" bindtap="clearDraft">清空本地漫步草稿</button>
</view>
