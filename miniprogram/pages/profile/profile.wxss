.profile-page {
  background: linear-gradient(180deg, #f4efe6 0%, #efe7da 100%);
}

.profile-card {
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(77, 62, 38, 0.08);
  animation: profile-panel-enter 340ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.profile-card-head {
  margin-bottom: 26rpx;
}

.profile-kicker {
  display: inline-block;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  font-size: 21rpx;
  line-height: 1.25;
}

.profile-title {
  margin-top: 18rpx;
  color: #241f19;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
}

.profile-subtitle {
  margin-top: 12rpx;
  color: #746b5f;
  font-size: 24rpx;
  line-height: 1.62;
}

.profile-skeleton-block {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.profile-skeleton-avatar {
  width: 116rpx;
  height: 116rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  background: rgba(126, 111, 89, 0.14);
}

.profile-skeleton-copy {
  flex: 1;
}

.profile-skeleton-line {
  position: relative;
  overflow: hidden;
  height: 22rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: rgba(126, 111, 89, 0.14);
}

.profile-skeleton-line-main {
  width: 72%;
  height: 28rpx;
  margin-top: 0;
}

.profile-cover-row,
.profile-setup-row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  background: #efe7da;
  display: block;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #626247;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 750;
  box-shadow: inset 0 0 0 1rpx rgba(98, 98, 71, 0.16);
}

.profile-avatar-picker {
  width: 128rpx;
  min-width: 128rpx;
  max-width: 128rpx;
  height: 128rpx;
  min-height: 128rpx;
  max-height: 128rpx;
  flex: 0 0 128rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 28rpx;
  background: #efe7da;
  box-sizing: border-box;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.profile-avatar-picker .profile-avatar,
.profile-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: inherit;
}

.profile-summary-copy,
.profile-form-block {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.profile-summary-label {
  color: #9a9082;
  font-size: 21rpx;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.profile-summary-name {
  color: #241f19;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  word-break: break-word;
}

.profile-summary-desc {
  margin-top: 10rpx;
  color: #746b5f;
  font-size: 23rpx;
  line-height: 1.55;
}

.profile-status-panel {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #faf4ea;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.14);
}

.profile-status-title {
  color: #241f19;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.profile-status-desc {
  margin-top: 10rpx;
  color: #746b5f;
  font-size: 24rpx;
  line-height: 1.65;
}

.profile-nickname-input {
  width: 100%;
  min-height: 48rpx;
  padding: 0 0 8rpx;
  border-radius: 0;
  background: transparent;
  border: 0;
  border-bottom: 1rpx solid rgba(126, 111, 89, 0.24);
  box-sizing: border-box;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #241f19;
}

.profile-input-tip,
.profile-inline-error {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.55;
}

.profile-input-tip {
  color: #746b5f;
}

.profile-inline-error {
  color: #a55449;
}

.profile-action-row,
.profile-action-stack {
  margin-top: 26rpx;
  width: 380rpx;
  max-width: 100%;
  margin-left: auto;
  margin-right: auto;
}

.profile-action-row,
.profile-action-stack {
  display: flex;
  flex-direction: column;
}

.profile-action-row .profile-action-btn,
.profile-action-stack .profile-action-btn {
  margin-top: 14rpx;
}

.profile-action-row .profile-action-btn:first-child,
.profile-action-stack .profile-action-btn:first-child {
  margin-top: 0;
}

.profile-action-btn {
  flex: none;
  width: 100%;
  box-sizing: border-box;
}

.profile-logout-btn {
  color: #a55449;
  background: rgba(165, 84, 73, 0.08);
  box-shadow: inset 0 0 0 1rpx rgba(165, 84, 73, 0.18);
}

@keyframes profile-panel-enter {
  0% {
    opacity: 0;
    transform: translateY(16rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
