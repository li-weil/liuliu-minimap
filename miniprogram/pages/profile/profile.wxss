.profile-hero,
.profile-card,
.profile-section {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.profile-status-block {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #faf5eb 0%, #f4ead9 100%);
  border: 1rpx solid #eadcc5;
}

.profile-status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3c2f1d;
}

.profile-status-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a7d66;
}

.profile-setup-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 22rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #ede8de;
  flex-shrink: 0;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7f7669;
  font-size: 34rpx;
  font-weight: 600;
}

.profile-avatar-picker {
  width: 96rpx;
  height: 96rpx;
  min-width: 96rpx;
  flex: 0 0 96rpx;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.profile-nickname-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #f8f4ed 0%, #f2eadf 100%);
  border: 1rpx solid #e8dece;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #2f2b24;
}

.profile-form-block {
  min-width: 0;
  flex: 1;
  margin-left: -2rpx;
}

.profile-input-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a8173;
}

.profile-view-block {
  display: flex;
  flex-direction: column;
}

.profile-summary-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-summary-copy {
  min-width: 0;
  flex: 1;
}

.profile-summary-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2b24;
}

.profile-meta-row {
  margin-top: 20rpx;
}

.profile-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.profile-action-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 26rpx;
}

.profile-action-btn {
  flex: 1;
  margin-bottom: 0;
  width: 100%;
  box-sizing: border-box;
}

.profile-logout-btn {
  margin-top: 0;
}

.profile-capability-card {
  padding: 20rpx;
  margin-bottom: 12rpx;
}
