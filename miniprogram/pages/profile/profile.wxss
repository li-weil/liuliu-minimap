.profile-hero,
.profile-card,
.profile-section {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.profile-user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #ede8de;
  flex-shrink: 0;
}

.profile-copy {
  min-width: 0;
  flex: 1;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2f2b24;
}

.profile-meta-id {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7f7a6f;
  word-break: break-all;
}

.profile-meta-row {
  margin-top: 20rpx;
}

.profile-login-btn,
.profile-draft-btn,
.profile-logout-btn {
  margin-bottom: 24rpx;
}

.profile-logout-btn {
  margin-top: 24rpx;
}

.profile-capability-card {
  padding: 20rpx;
  margin-bottom: 12rpx;
}
