<view class="page-shell">
  <view wx:if="{{loading}}" class="empty-copy">正在加载足迹详情...</view>

  <view wx:elif="{{walk}}">
    <view class="theme-card" style="padding: 28rpx; margin-bottom: 24rpx; border-top: 10rpx solid {{walk.themeSnapshot.vibeColor || '#5a5a40'}};">
      <view class="meta-row" style="margin-bottom: 16rpx;">
        <view class="meta-pill">{{source === 'feed' ? '来自社区' : '我的足迹'}}</view>
        <view class="meta-pill">{{walk.walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}</view>
        <view class="meta-pill">{{walk.generationSource || 'unknown'}}</view>
      </view>
      <view style="font-size: 40rpx; font-weight: 600; margin-bottom: 14rpx;">{{walk.themeTitle}}</view>
      <view style="color: #6f6a5f; line-height: 1.7; margin-bottom: 16rpx;">{{walk.themeSnapshot.description}}</view>
      <view class="meta-row">
        <view class="meta-pill">{{walk.locationName}}</view>
        <view class="meta-pill">{{walk.locationContext}}</view>
        <view class="meta-pill">{{walk.createdAtLabel}}</view>
      </view>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">任务结果</view>
      <view wx:for="{{walk.missionItems}}" wx:key="mission" class="mission-card" style="padding: 20rpx; margin-bottom: 14rpx;">
        <view style="display: flex; justify-content: space-between; gap: 18rpx; align-items: center; margin-bottom: 10rpx;">
          <view style="font-weight: 600; flex: 1;">{{item.mission}}</view>
        </view>
        <view wx:if="{{item.assets}}" class="meta-row" style="margin-top: 12rpx;">
          <view class="meta-pill" wx:if="{{item.assets.photoList && item.assets.photoList.length}}">{{item.assets.photoList.length}} 张图片</view>
          <view class="meta-pill" wx:if="{{item.assets.videoList && item.assets.videoList.length}}">{{item.assets.videoList.length}} 段视频</view>
          <view class="meta-pill" wx:if="{{item.assets.audioList && item.assets.audioList.length}}">{{item.assets.audioList.length}} 段录音</view>
        </view>
      </view>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">地图与轨迹</view>
      <map longitude="{{walk.routePoints.length ? walk.routePoints[walk.routePoints.length - 1].longitude : 116.39747}}" latitude="{{walk.routePoints.length ? walk.routePoints[walk.routePoints.length - 1].latitude : 39.908823}}" scale="15" show-location polyline="{{[{ points: walk.routePoints, color: '#5a5a40', width: 4 }]}}" style="width: 100%; height: 360rpx; border-radius: 22rpx; overflow: hidden;" />
      <view class="meta-row" style="margin-top: 20rpx;">
        <view class="meta-pill">{{walk.routeStats.distanceLabel || '0 m'}}</view>
        <view class="meta-pill">{{walk.routeStats.durationLabel || '0秒'}}</view>
        <view class="meta-pill">{{walk.isPublic ? '已公开' : '仅自己可见'}}</view>
      </view>
      <view class="meta-row" style="margin-top: 16rpx;">
        <view class="meta-pill">开始 {{walk.routeStats.startedLabel || '未记录'}}</view>
        <view class="meta-pill">结束 {{walk.routeStats.stoppedLabel || '未记录'}}</view>
      </view>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">图片记录</view>
      <view wx:if="{{walk.photoList.length}}" style="display: flex; flex-wrap: wrap; gap: 16rpx;">
        <image wx:for="{{walk.photoList}}" wx:key="index" src="{{item}}" mode="aspectFill" style="width: 208rpx; height: 208rpx; border-radius: 18rpx;" />
      </view>
      <view wx:else class="empty-copy" style="padding: 20rpx 0;">这次漫步没有上传图片。</view>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">视频记录</view>
      <view wx:if="{{walk.videoList.length}}">
        <video
          wx:for="{{walk.videoList}}"
          wx:key="index"
          src="{{item}}"
          controls
          objectFit="cover"
          style="width: 100%; height: 360rpx; border-radius: 18rpx; margin-bottom: 16rpx;"
        />
      </view>
      <view wx:else class="empty-copy" style="padding: 20rpx 0;">这次漫步没有上传视频。</view>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">录音记录</view>
      <view wx:if="{{walk.audioList.length}}">
        <view wx:for="{{walk.audioList}}" wx:key="index" class="mission-card" style="padding: 18rpx 20rpx; margin-bottom: 14rpx;">
          <view style="font-size: 24rpx; font-weight: 600; margin-bottom: 12rpx;">录音 {{index + 1}}</view>
          <audio src="{{item}}" controls style="width: 100%;" />
        </view>
      </view>
      <view wx:else class="empty-copy" style="padding: 20rpx 0;">这次漫步没有上传录音。</view>
    </view>

    <view class="section-card" style="padding: 28rpx;">
      <view class="section-title">文字记录</view>
      <view style="color: #6f6a5f; line-height: 1.8;">{{walk.noteText || '这次漫步还没有留下文字记录。'}}</view>
    </view>
  </view>

  <view wx:else class="empty-copy">没有找到这条足迹。</view>

</view>
