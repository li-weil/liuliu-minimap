<view class="page-shell">
  <view wx:if="{{loading}}" class="empty-copy">正在加载足迹详情...</view>

  <view wx:elif="{{walk}}">
    <view class="theme-card" style="padding: 28rpx; margin-bottom: 24rpx; border-top: 10rpx solid {{walk.themeSnapshot.vibeColor || '#5a5a40'}};">
      <view class="meta-row" style="margin-bottom: 16rpx;">
        <view class="meta-pill">{{source === 'feed' || source === 'share' ? '来自分享' : '我的足迹'}}</view>
        <view class="meta-pill">{{walk.status === 'active' ? '进行中' : '已结束'}}</view>
        <view class="meta-pill">{{walk.walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}</view>
      </view>
      <view style="font-size: 40rpx; font-weight: 600; margin-bottom: 14rpx;">{{walk.themeTitle}}</view>
      <view style="color: #6f6a5f; line-height: 1.7; margin-bottom: 16rpx;">{{walk.themeSnapshot.description}}</view>
      <view class="meta-row">
        <view class="meta-pill">{{walk.locationName}}</view>
        <view class="meta-pill">{{walk.createdAtLabel}}</view>
      </view>
      <button wx:if="{{canResume}}" class="primary-btn walk-resume-btn" bindtap="handleResumeWalk">继续记录这次漫步</button>
    </view>

    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">地图位置</view>
      <map longitude="{{mapCenterLongitude}}" latitude="{{mapCenterLatitude}}" scale="15" show-location style="width: 100%; height: 360rpx; border-radius: 22rpx; overflow: hidden;" />
      <view class="meta-row" style="margin-top: 20rpx;">
        <view class="meta-pill">{{walk.routeStats.distanceLabel || '0 m'}}</view>
        <view class="meta-pill">{{walk.routeStats.durationLabel || '0秒'}}</view>
        <view class="meta-pill">{{walk.isPublic ? '可分享给好友' : '仅自己可见'}}</view>
      </view>
      <view class="meta-row" style="margin-top: 16rpx;">
        <view class="meta-pill">开始 {{walk.routeStats.startedLabel || '未记录'}}</view>
        <view class="meta-pill">结束 {{walk.routeStats.stoppedLabel || '未记录'}}</view>
      </view>
    </view>
    
    <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
      <view class="section-title">任务记录</view>
      <view wx:if="{{walk.missionItems.length}}" class="mission-list-block">
        <block wx:for="{{walk.missionItems}}" wx:key="mission" wx:for-item="missionItem">
          <view class="mission-group">
            <view
              class="mission-row {{activeMission === missionItem.mission ? 'mission-row-active' : ''}}"
              bindtap="switchMissionTab"
              data-mission="{{missionItem.mission}}"
            >
              <view wx:if="{{missionItem.isSupplemental}}" class="mission-tag">总结与补充</view>
              <view wx:else class="mission-anchor {{activeMission === missionItem.mission ? 'mission-anchor-active' : ''}}"></view>
              <view class="mission-copy">{{missionItem.label}}</view>
            </view>

            <view wx:if="{{activeMission === missionItem.mission}}" class="mission-detail-block">
              <view class="meta-row mission-detail-meta">
                <view class="meta-pill" wx:if="{{missionItem.assets.photoList && missionItem.assets.photoList.length}}">{{missionItem.assets.photoList.length}} 张图片</view>
                <view class="meta-pill" wx:if="{{missionItem.assets.videoList && missionItem.assets.videoList.length}}">{{missionItem.assets.videoList.length}} 段视频</view>
                <view class="meta-pill" wx:if="{{missionItem.assets.audioList && missionItem.assets.audioList.length}}">{{missionItem.assets.audioList.length}} 段录音</view>
              </view>

              <view class="mission-detail-note">
                {{missionItem.assets.noteText || '这个任务下还没有留下文字记录'}}
              </view>



              <view class="mission-media-group">
                <view class="section-subtitle">图片记录</view>
                <view wx:if="{{missionItem.assets.photoList.length}}" style="display: flex; flex-wrap: wrap; gap: 16rpx;">
                  <image wx:for="{{missionItem.assets.photoList}}" wx:key="index" src="{{item}}" mode="aspectFill" style="width: 208rpx; height: 208rpx; border-radius: 18rpx;" />
                </view>
                <view wx:else class="empty-copy" style="padding: 20rpx 0;">这个任务下没有图片记录</view>
              </view>

              <view class="mission-media-group">
                <view class="section-subtitle">视频记录</view>
                <view wx:if="{{missionItem.assets.videoList.length}}">
                  <video
                    wx:for="{{missionItem.assets.videoList}}"
                    wx:key="index"
                    src="{{item.tempFilePath || item}}"
                    controls
                    objectFit="cover"
                    style="width: 100%; height: 360rpx; border-radius: 18rpx; margin-bottom: 16rpx;"
                  />
                </view>
                <view wx:else class="empty-copy" style="padding: 20rpx 0;">这个任务下没有视频记录</view>
              </view>

              <view class="mission-media-group">
                <view class="section-subtitle">录音记录</view>
                <view wx:if="{{missionItem.assets.audioList.length}}">
                  <view wx:for="{{missionItem.assets.audioList}}" wx:key="index" class="mission-card audio-card">
                    <view style="font-size: 24rpx; font-weight: 600; margin-bottom: 12rpx;">录音 {{index + 1}}</view>
                    <audio-player src="{{item.tempFilePath || item}}" />
                  </view>
                </view>
                <view wx:else class="empty-copy" style="padding: 20rpx 0;">这个任务下没有录音记录</view>
              </view>

              <view class="mission-card-preview">
                <view class="section-subtitle">打卡卡片</view>
                <view wx:if="{{isRenderingMissionCard}}" class="mission-card-preview-loading">66 正在整理这张卡片...</view>
                <view wx:elif="{{missionCardPendingNote}}" class="mission-card-preview-loading">{{missionCardPendingText}}</view>
                <image
                  wx:elif="{{currentMissionCardSrc}}"
                  class="mission-card-preview-image"
                  src="{{currentMissionCardSrc}}"
                  mode="widthFix"
                  bindtap="openMissionCardModal"
                  data-src="{{currentMissionCardSrc}}"
                  data-title="{{missionItem.label || '打卡卡片'}}"
                />
                <view wx:else class="empty-copy" style="padding: 20rpx 0;">还没有生成卡片</view>
                <button wx:if="{{!currentMissionCardSrc}}" class="ghost-btn" bindtap="handleGenerateMissionCard" disabled="{{missionCardPendingNote}}">
                  生成卡片
                </button>
              </view>    

            </view>
          </view>
        </block>
      </view>
      <view wx:if="{{!walk.missionItems.length}}" class="empty-copy" style="padding: 20rpx 0;">
        这次漫步还没有任务级记录。
      </view>
    </view>

    <button
      wx:if="{{walk.canShare}}"
      class="primary-btn share-action-btn"
      open-type="share"
      bindtap="handleShareTap"
    >
      分享
    </button>

    <button wx:if="{{walk.canDelete}}" class="danger-action-btn" bindtap="handleDeleteWalk" loading="{{isDeletingWalk}}" disabled="{{isDeletingWalk}}">
      删除这条历史记录
    </button>


  </view>

  <view wx:else class="empty-copy">没有找到这条足迹。</view>

  <checkin-card
    wx:if="{{isRenderingMissionCard && missionCardRenderPayload.renderVersion > 0}}"
    mission="{{missionCardRenderPayload.mission}}"
    assets="{{missionCardRenderPayload.assets}}"
    locationName="{{missionCardRenderPayload.locationName}}"
    themeTitle="{{missionCardRenderPayload.themeTitle}}"
    dateLabel="{{missionCardRenderPayload.dateLabel}}"
    renderVersion="{{missionCardRenderPayload.renderVersion}}"
    autoRender="{{true}}"
    bind:generated="handleMissionCardGenerated"
  />

  <view wx:if="{{showMissionCardModal}}" class="mission-card-modal-mask" catchtap="closeMissionCardModal">
    <view class="mission-card-modal-sheet" catchtap="noop">
      <view class="mission-card-modal-panel">
        <view class="mission-card-modal-title">{{missionCardModal.title || '打卡卡片'}}</view>
        <scroll-view scroll-y class="mission-card-modal-scroll">
          <image wx:if="{{missionCardModal.imageSrc}}" class="mission-card-modal-image" src="{{missionCardModal.imageSrc}}" mode="widthFix" />
        </scroll-view>
      </view>
      <view class="mission-card-modal-actions">
        <button class="ghost-btn mission-card-modal-action" bindtap="closeMissionCardModal">关闭</button>
        <button class="primary-btn mission-card-modal-action" bindtap="handleSaveMissionCardToAlbum">保存到本地</button>
      </view>
    </view>
  </view>

</view>

<privacy-consent
  visible="{{privacyPopup.visible}}"
  title="{{privacyPopup.title}}"
  content="{{privacyPopup.content}}"
  buttonText="{{privacyPopup.buttonText}}"
  contractName="{{privacyPopup.contractName}}"
  bind:agree="handlePrivacyAgree"
  bind:close="handlePrivacyReject"
  bind:opencontract="handleOpenPrivacyContract"
/>
