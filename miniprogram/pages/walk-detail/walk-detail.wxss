.sticker-detail-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  min-height: 760rpx;
  background: #f4ecdf;
}

.sticker-detail-image {
  width: 100%;
  height: 760rpx;
  display: block;
}

.sticker-detail-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(32, 26, 17, 0.04), rgba(32, 26, 17, 0.3));
}

.sticker-detail-poem {
  align-self: flex-end;
  max-width: 58%;
  display: flex;
  flex-direction: row-reverse;
  gap: 16rpx;
  color: #fffaf2;
  font-weight: 600;
  text-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(34, 29, 22, 0.16), rgba(34, 29, 22, 0.08));
  backdrop-filter: blur(8rpx);
}

.sticker-detail-poem-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.sticker-detail-poem-char {
  font-size: 50rpx;
  line-height: 1;
  font-style: italic;
}

.sticker-detail-title {
  align-self: flex-start;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: rgba(255, 250, 242, 0.92);
  background: rgba(34, 29, 22, 0.28);
}

.sticker-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 17, 12, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 30;
}

.sticker-modal-sheet {
  width: 100%;
  max-width: 680rpx;
}

.sticker-modal-card {
  position: relative;
  border-radius: 40rpx;
  overflow: hidden;
  min-height: 960rpx;
  background: #f4ecdf;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
}

.sticker-modal-image {
  width: 100%;
  height: 960rpx;
  display: block;
}

.sticker-modal-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(39, 32, 20, 0.04), rgba(39, 32, 20, 0.34));
}

.sticker-modal-poem {
  align-self: flex-end;
  max-width: 62%;
  display: flex;
  flex-direction: row-reverse;
  gap: 18rpx;
  color: #fffaf2;
  font-weight: 600;
  text-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.22);
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(34, 29, 22, 0.18), rgba(34, 29, 22, 0.08));
  backdrop-filter: blur(10rpx);
}

.sticker-modal-poem-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.sticker-modal-poem-char {
  font-size: 58rpx;
  line-height: 1;
  font-style: italic;
}

.sticker-modal-theme {
  align-self: flex-start;
  font-size: 28rpx;
  color: rgba(255, 250, 242, 0.94);
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(34, 29, 22, 0.28);
}

.sticker-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.sticker-modal-action {
  flex: 1;
}
