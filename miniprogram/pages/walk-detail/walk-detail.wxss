.mission-list-block {
  margin-top: 20rpx;
}

.walk-resume-btn {
  margin-top: 22rpx;
}

.mission-group {
  margin-bottom: 12rpx;
}

.mission-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ede4d7;
}

.mission-row-active .mission-copy {
  color: #2f2b24;
  font-weight: 600;
}

.mission-anchor {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d8ccbb;
  flex-shrink: 0;
}

.mission-anchor-active {
  background: #6c6a49;
  box-shadow: 0 0 0 10rpx rgba(108, 106, 73, 0.12);
}

.mission-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #efe6d8;
  color: #6f675c;
  font-size: 22rpx;
  line-height: 1.2;
}

.mission-copy {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6f675c;
}

.mission-detail-block {
  margin-top: 10rpx;
  margin-left: 34rpx;
  border: 1rpx solid #eadfce;
  border-radius: 36rpx;
  padding: 22rpx 18rpx 18rpx;
  background: #fffdf9;
  box-sizing: border-box;
}

.mission-detail-meta {
  margin-top: 0;
}

.mission-detail-note {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: #f7f1e8;
  color: #6f6a5f;
  line-height: 1.8;
}

.mission-card-preview {
  margin-top: 20rpx;
}

.mission-card-preview-loading {
  min-height: 280rpx;
  margin-top: 12rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #f7f1e8;
  color: #8a8173;
  font-size: 26rpx;
  line-height: 1.7;
}

.mission-card-preview-image {
  width: 100%;
  display: block;
  margin-top: 12rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(79, 68, 50, 0.08);
}

.mission-media-group {
  margin-top: 24rpx;
}

.mission-audio-scroll {
  width: 100%;
  white-space: nowrap;
}

.mission-audio-player-wrap {
  min-width: 640rpx;
  border-radius: 22rpx;
}

.mission-audio-player {
  width: 640rpx;
  display: block;
}

.danger-action-btn {
  width: calc(100% - 64rpx);
  margin: 8rpx 32rpx 0;
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #f7e7e1;
  color: #b04933;
  border: 1rpx solid #efc9bf;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  box-sizing: border-box;
}

.sticker-detail-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  min-height: 760rpx;
  background: #f4ecdf;
}

.sticker-detail-image {
  width: 100%;
  height: 760rpx;
  display: block;
}

.sticker-detail-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(32, 26, 17, 0.04), rgba(32, 26, 17, 0.3));
}

.sticker-detail-poem {
  align-self: flex-end;
  max-width: 58%;
  display: flex;
  flex-direction: row-reverse;
  gap: 16rpx;
  color: #fffaf2;
  font-weight: 600;
  text-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(34, 29, 22, 0.16), rgba(34, 29, 22, 0.08));
  backdrop-filter: blur(8rpx);
}

.sticker-detail-poem-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.sticker-detail-poem-char {
  font-size: 50rpx;
  line-height: 1;
  font-style: italic;
}

.sticker-detail-title {
  align-self: flex-start;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: rgba(255, 250, 242, 0.92);
  background: rgba(34, 29, 22, 0.28);
}

.sticker-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 17, 12, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 30;
}

.sticker-modal-sheet {
  width: 100%;
  max-width: 680rpx;
}

.sticker-modal-card {
  position: relative;
  border-radius: 40rpx;
  overflow: hidden;
  min-height: 960rpx;
  background: #f4ecdf;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
}

.sticker-modal-image {
  width: 100%;
  height: 960rpx;
  display: block;
}

.sticker-modal-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(39, 32, 20, 0.04), rgba(39, 32, 20, 0.34));
}

.sticker-modal-poem {
  align-self: flex-end;
  max-width: 62%;
  display: flex;
  flex-direction: row-reverse;
  gap: 18rpx;
  color: #fffaf2;
  font-weight: 600;
  text-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.22);
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(34, 29, 22, 0.18), rgba(34, 29, 22, 0.08));
  backdrop-filter: blur(10rpx);
}

.sticker-modal-poem-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.sticker-modal-poem-char {
  font-size: 58rpx;
  line-height: 1;
  font-style: italic;
}

.sticker-modal-theme {
  align-self: flex-start;
  font-size: 28rpx;
  color: rgba(255, 250, 242, 0.94);
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(34, 29, 22, 0.28);
}

.sticker-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.sticker-modal-action {
  flex: 1;
}

.mission-card-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 17, 12, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  z-index: 40;
}

.mission-card-modal-sheet {
  width: 100%;
  max-width: 680rpx;
  max-height: calc(100vh - 72rpx);
  display: flex;
  flex-direction: column;
}

.mission-card-modal-panel {
  border-radius: 36rpx;
  background: linear-gradient(180deg, #f7f1e8 0%, #efe5d5 100%);
  padding: 24rpx;
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.22);
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.mission-card-modal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 18rpx;
  flex-shrink: 0;
}

.mission-card-modal-scroll {
  max-height: calc(100vh - 280rpx);
  min-height: 360rpx;
}

.mission-card-modal-image {
  width: 100%;
  display: block;
  border-radius: 28rpx;
  overflow: hidden;
}

.mission-card-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mission-card-modal-action {
  flex: 1;
}
