.team-hero,
.team-block {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.team-hero-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.team-hero-copy,
.mission-tab-meta,
.activity-copy,
.complete-copy,
.asset-file {
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f6a5f;
}

.member-strip,
.editor-actions,
.action-stack {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.member-strip {
  flex-wrap: wrap;
}

.member-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f2ed;
  color: #5a5a40;
  font-size: 22rpx;
}

.mission-tabs {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.mission-tab {
  padding: 20rpx;
  border-radius: 28rpx;
  background: #f7f2ea;
  border: 1rpx solid transparent;
}

.mission-tab-active {
  border-color: #5a5a40;
  background: rgba(90, 90, 64, 0.08);
}

.mission-tab-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2b24;
  margin-bottom: 6rpx;
}

.asset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-item {
  padding: 12rpx;
  border-radius: 20rpx;
  background: #f7f2ea;
}

.asset-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: block;
}

.asset-remove {
  margin-top: 10rpx;
  color: #b74d42;
  font-size: 22rpx;
}

.complete-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 20rpx 0;
}

.save-progress-card {
  margin: 20rpx 0 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(90, 90, 64, 0.08);
}

.submit-action-row {
  margin-top: 32rpx;
}

.submit-action-btn {
  width: 100%;
}

.save-progress-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2f2b24;
}

.save-progress-meta {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 22rpx;
  color: #6f6a5f;
}

.save-progress-track {
  margin-top: 14rpx;
  height: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(90, 90, 64, 0.14);
}

.save-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #5a5a40 0%, #8a7b55 100%);
}

.complete-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  border: 4rpx solid #b8b1a3;
}

.complete-check-active {
  background: #5a5a40;
  border-color: #5a5a40;
}

.activity-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.activity-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-stack {
  flex-direction: column;
  margin-bottom: 24rpx;
}

.team-empty {
  padding: 20rpx 0;
}
