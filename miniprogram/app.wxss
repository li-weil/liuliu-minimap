page {
  background: #f4efe6;
  color: #241f19;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.section-card,
.theme-card,
.walk-card,
.mission-card {
  background: #fffdf8;
  border: 1rpx solid rgba(126, 111, 89, 0.16);
  border-radius: 32rpx;
  box-shadow: 0 14rpx 34rpx rgba(77, 62, 38, 0.08);
}

.section-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 650;
  color: #241f19;
  margin-bottom: 10rpx;
}

.section-subtitle {
  color: #746b5f;
  font-size: 24rpx;
  line-height: 1.65;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.pill,
.pill-active {
  min-height: 64rpx;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
  transition-property: transform, opacity, background-color, box-shadow;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.pill {
  background: #efe7da;
  color: #3a332b;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.12);
}

.pill-active {
  background: rgba(98, 98, 71, 0.12);
  color: #3f402f;
  box-shadow: inset 0 0 0 2rpx rgba(98, 98, 71, 0.36);
}

.pill:active,
.pill-active:active,
.walk-card:active,
.mission-card:active,
.theme-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  min-height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1.2;
  text-align: center;
  padding: 22rpx 28rpx;
  transition-property: transform, opacity, background-color, box-shadow;
  transition-duration: 180ms;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

.primary-btn:active,
.secondary-btn:active,
.ghost-btn:active,
.danger-btn:active {
  transform: translateY(1rpx) scale(0.985);
  opacity: 0.92;
}

.primary-btn {
  background: #626247;
  color: #fffdf8;
  box-shadow: 0 12rpx 24rpx rgba(63, 64, 47, 0.18);
}

.secondary-btn {
  background: #3f402f;
  color: #fffdf8;
  box-shadow: 0 12rpx 24rpx rgba(63, 64, 47, 0.16);
}

.ghost-btn {
  background: #faf4ea;
  color: #3f402f;
  box-shadow: inset 0 0 0 1rpx rgba(126, 111, 89, 0.18);
}

.danger-btn {
  background: #a55449;
  color: #fffdf8;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #746b5f;
}

.text-input,
.text-area {
  width: 100%;
  background: #fffdf8;
  border-radius: 24rpx;
  border: 1rpx solid rgba(126, 111, 89, 0.18);
  box-sizing: border-box;
  color: #241f19;
}

.text-input {
  min-height: 84rpx;
  padding: 20rpx 24rpx;
}

.text-area {
  min-height: 180rpx;
  padding: 24rpx;
}

.empty-copy {
  text-align: center;
  padding: 72rpx 24rpx;
  color: #746b5f;
  line-height: 1.7;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(98, 98, 71, 0.1);
  color: #626247;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
}
